{% layout none %}

<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Mulish:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {% style %}
      .pt-gc-body { margin: 0; background: var(--pt-bg); }
      .pt-gc { position: relative; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 48px 24px; overflow: hidden; font-family: var(--pt-font-body); }
      .pt-gc-glow { position: absolute; width: 700px; height: 700px; border-radius: 50%; top: -260px; left: 50%; transform: translateX(-50%); background: radial-gradient(circle, var(--pt-accent-soft), transparent 70%); filter: blur(20px); pointer-events: none; }
      .pt-gc-wrap { position: relative; z-index: 1; width: 100%; max-width: 460px; display: flex; flex-direction: column; align-items: center; }
      .pt-gc-logo { margin-bottom: 28px; }
      .pt-gc-logo img { max-height: 40px; width: auto; }
      .pt-gc-card { width: 100%; background: linear-gradient(160deg, #fff, var(--pt-accent-soft)); border: 1px solid var(--pt-line); border-radius: calc(var(--pt-radius) + 8px); box-shadow: var(--pt-shadow-md); padding: 44px 36px; text-align: center; }
      .pt-gc-card-top { display: flex; flex-direction: column; align-items: center; }
      .pt-gc-eyebrow { margin-bottom: 6px; }
      .pt-gc-balance { font-family: var(--pt-font-head); font-size: clamp(2.6rem, 8vw, 3.6rem); margin: 0; color: var(--pt-ink); }
      .pt-gc-expired { display: inline-block; margin-top: 10px; font-size: 12px; font-weight: 800; letter-spacing: .06em; text-transform: uppercase; color: #a23f4a; background: #fdecef; border-radius: 999px; padding: 5px 14px; }
      .pt-gc-expires { color: var(--pt-ink-soft); font-size: 13.5px; margin: 10px 0 0; }
      .pt-gc-code-wrap { margin: 30px 0; padding: 20px; background: #fff; border-radius: var(--pt-radius); border: 1px dashed var(--pt-line); }
      .pt-gc-code-wrap img { max-width: 100%; height: auto; margin: 0 auto; }
      .pt-gc-use { color: var(--pt-ink-soft); font-size: 14px; margin: 0; }
      .pt-gc-wallet { display: inline-block; margin-top: 20px; }
      .pt-gc-wallet img { height: 44px; width: auto; }
      .pt-gc-print { margin-top: 28px; }
      .pt-gc-shop { margin-top: 20px; font-family: var(--pt-font-head); font-size: 18px; color: var(--pt-ink-soft); }
      .pt-gc-eyebrow, .pt-gc-print { font-family: var(--pt-font-body); }
      .pt-gc-print { display: inline-flex; align-items: center; gap: 8px; }
      @media print {
        .pt-gc-glow, .pt-gc-print { display: none; }
        .pt-gc { padding: 0; min-height: 0; }
        .pt-gc-card { box-shadow: none; }
      }
      @media (max-width: 480px) {
        .pt-gc-card { padding: 32px 22px; }
      }
    {% endstyle %}

    {{ content_for_header }}
  </head>

  <body class="pt-gc-body">
    <main class="pt-gc">
      <div class="pt-gc-glow"></div>

      <div class="pt-gc-wrap">
        <a href="{{ routes.root_url }}" class="pt-logo pt-gc-logo">
          {%- if settings.logo -%}
            {{ settings.logo | image_url: width: 220 | image_tag: alt: shop.name }}
          {%- else -%}
            <svg width="17" height="17" viewBox="0 0 24 24" fill="var(--pt-accent)" style="margin-right:2px" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
            {{ shop.name }}
          {%- endif -%}
        </a>

        <div class="pt-gc-card">
          <div class="pt-gc-card-top">
            <span class="pt-eyebrow pt-gc-eyebrow">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
              {{ 'gift_card.card' | t }}
            </span>
            <h1 class="pt-gc-balance">{{ gift_card.balance | money }}</h1>

            {%- if gift_card.enabled == false or gift_card.expired -%}
              <span class="pt-gc-expired">{{ 'gift_card.expired' | t }}</span>
            {%- elsif gift_card.expires_on -%}
              {%- assign expires_on = gift_card.expires_on | date: '%B %e, %Y' -%}
              <p class="pt-gc-expires">{{ 'gift_card.expires_on' | t: expires_on: expires_on }}</p>
            {%- endif -%}
          </div>

          <div class="pt-gc-code-wrap">
            {{ gift_card.code | format_code }}
          </div>

          <p class="pt-gc-use">{{ 'gift_card.use_at_checkout' | t }}</p>

          {%- if gift_card.pass_url -%}
            <a href="{{ gift_card.pass_url }}" class="pt-gc-wallet">
              <img
                src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}"
                alt="{{ 'gift_card.add_to_apple_wallet' | t }}"
                width="200"
                height="48"
              >
            </a>
          {%- endif -%}
        </div>

        <button type="button" class="pt-btn pt-btn--ghost pt-gc-print" data-gc-print>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M6 9V3h12v6M6 18H4a1 1 0 0 1-1-1v-6a1 1 0 0 1 1-1h16a1 1 0 0 1 1 1v6a1 1 0 0 1-1 1h-2M6 14h12v7H6z" stroke-linejoin="round"/></svg>
          {{ 'gift_card.print' | t }}
        </button>

        <p class="pt-gc-shop">{{ shop.name }}</p>
      </div>
    </main>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        var btn = document.querySelector('[data-gc-print]');
        if (btn) btn.addEventListener('click', function () { window.print(); });
      });
    </script>
  </body>
</html>

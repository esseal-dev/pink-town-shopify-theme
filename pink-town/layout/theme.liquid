<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% render 'css-variables' %}

    {% unless settings.type_heading_font.system? and settings.type_body_font.system? %}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
      {% unless settings.type_heading_font.system? %}
        {{ settings.type_heading_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
      {% endunless %}
      {% unless settings.type_body_font.system? %}
        {{ settings.type_body_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
      {% endunless %}
    {% endunless %}

    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% if settings.favicon != blank %}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {% endif %}

    {% render 'meta-tags' %}

    {{ content_for_header }}
  </head>

  <body>
    <a class="pt-skip-link" href="#main-content">{{ 'general.accessibility.skip_to_content' | t }}</a>

    {% sections 'header-group' %}

    <main id="main-content">
      {%- comment -%}
        Shopify always renders its own built-in markup for shop policy pages
        (Privacy Policy, Terms of Service, Refund Policy, Shipping Policy) and
        ignores any templates/policy.liquid or .json file entirely. The only
        documented way to apply theme styling to them is to intercept here in
        the layout and render our own section instead of the default output.
      {%- endcomment -%}
      {%- if request.path contains '/policies/' -%}
        {% section 'main-policy' %}
      {%- else -%}
        {{ content_for_layout }}
      {%- endif -%}
    </main>

    {% sections 'footer-group' %}

    {{ 'pinktown.js' | asset_url | script_tag }}
  </body>
</html>

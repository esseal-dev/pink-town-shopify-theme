{% doc %}
  Renders one of a small curated set of outline icons, used by the "Our
  promise" value cards (and reusable anywhere a merchant needs to pick a
  simple icon from a dropdown rather than upload custom artwork).

  @param {string} icon - One of: heart, check, sparkle, gift

  @example
  {% render 'value-icon', icon: 'heart' %}
{% enddoc %}

{%- case icon -%}
  {%- when 'heart' -%}
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 21s-7.5-4.9-10-9.6C.5 7.6 3 3.8 7 3.8c2.2 0 3.8 1.3 5 3 1.2-1.7 2.8-3 5-3 4 0 6.5 3.8 5 7.6-2.5 4.7-10 9.6-10 9.6z" stroke-linejoin="round"/></svg>
  {%- when 'check' -%}
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="8.5"/><path d="M9 12l2 2 4-4.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {%- when 'gift' -%}
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M4 8h16M4 8l1.2 11a2 2 0 0 0 2 1.8h9.6a2 2 0 0 0 2-1.8L20 8M9 8V6a3 3 0 0 1 6 0v2" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {%- else -%}
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
  {%- comment -%} 'sparkle' and any unrecognized value fall through to this shared sparkle glyph. {%- endcomment -%}
{%- endcase -%}

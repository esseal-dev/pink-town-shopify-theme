{% comment %}
  Product reviews host section. Reviews come from a review app installed by
  the merchant (Judge.me, Loox, Shopify Product Reviews, etc.) — the app's
  widget is inserted here as an app block. The theme itself stores no review
  data, so nothing misleading ships by default.
{% endcomment %}

{%- if section.blocks.size > 0 -%}
  <section class="pt-pdp-sec pt-pdp-sec--tint full-width" id="reviews">
    {%- if section.settings.heading != blank -%}
      <h2 class="pt-pdp-h pt-pdp-h--center">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="pt-rv-app-wrap">
      {%- for block in section.blocks -%}
        <div class="pt-rv-app-block" {{ block.shopify_attributes }}>
          {%- render block -%}
        </div>
      {%- endfor -%}
    </div>
  </section>
{%- elsif request.design_mode -%}
  <section class="pt-pdp-sec pt-pdp-sec--tint full-width" id="reviews">
    <div class="pt-rv-app-empty">
      <h2 class="pt-pdp-h pt-pdp-h--center">{{ 'sections.product_reviews.placeholder_heading' | t }}</h2>
      <p>{{ 'sections.product_reviews.placeholder_text' | t }}</p>
    </div>
  </section>
{%- endif -%}

{% stylesheet %}
  .pt-rv-app-wrap { max-width: var(--pt-wrap); margin: 36px auto 0; font-family: var(--pt-font-body); }
  .pt-rv-app-block { min-width: 0; }
  .pt-rv-app-empty { max-width: 560px; margin: 0 auto; text-align: center; font-family: var(--pt-font-body); }
  .pt-rv-app-empty p { font-size: 14px; line-height: 1.6; color: var(--pt-ink-soft); margin-top: 14px; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.product_reviews.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "t:sections.product_reviews.name"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}

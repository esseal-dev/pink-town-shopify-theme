{% comment %}
  This section is used in the list-collections template to render a list of
  collections.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/collection
{% endcomment %}

{%- liquid
  assign per_page = section.settings.collections_per_page | default: 24
-%}

<header class="pt-ch pt-ch--center full-width">
  <nav class="pt-crumb" aria-label="{{ 'general.accessibility.nav_left' | t }}">
    <a href="{{ routes.root_url }}">{{ 'sections.collection.breadcrumb_home' | t }}</a>
    <span>/</span>
    <b>{{ 'sections.collections_index.breadcrumb' | t }}</b>
  </nav>
  <span class="pt-eyebrow">
    <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
    {{ section.settings.eyebrow | escape }}
  </span>
  <h1 class="pt-ch-h">{{ section.settings.heading | escape }}</h1>
  {%- if section.settings.subheading != blank -%}
    <p class="pt-ch-blurb">{{ section.settings.subheading | escape }}</p>
  {%- endif -%}
</header>

{%- if collections.size == 0 -%}

  <div class="pt-empty pt-section full-width">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="var(--pt-accent)" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
    <h3>{{ 'sections.collections_index.empty_heading' | t }}</h3>
    <p>{{ 'sections.collections_index.empty_text' | t }}</p>
  </div>

{%- else -%}

  <section class="pt-section pt-coll-index full-width">
    {%- paginate collections by per_page -%}
      <div class="pt-coll-grid">
        {%- for collection in collections -%}
          <a href="{{ collection.url }}" class="pt-coll{% if forloop.first %} pt-coll--lg{% endif %}">
            {%- if collection.featured_image -%}
              {{ collection.featured_image | image_url: width: 1100 | image_tag: class: 'pt-ph-img', loading: 'lazy', alt: collection.featured_image.alt | default: collection.title }}
            {%- else -%}
              <div style="position:absolute;inset:0;background:linear-gradient(135deg,var(--pt-bg-tint),var(--pt-accent-soft));"></div>
            {%- endif -%}
            <div class="pt-coll-scrim"></div>
            <div class="pt-coll-body">
              <span class="pt-coll-count">{{ collection.products_count }} {% if collection.products_count == 1 %}{{ 'sections.featured_collections.piece' | t }}{% else %}{{ 'sections.featured_collections.pieces' | t }}{% endif %}</span>
              <h3 class="pt-coll-name">{{ collection.title | escape }}</h3>
              {%- if collection.description != blank -%}
                <p class="pt-coll-blurb">{{ collection.description | strip_html | truncate: 80 }}</p>
              {%- endif -%}
              <span class="pt-coll-link">{{ 'sections.featured_collections.shop_now' | t }}
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </div>
          </a>
        {%- endfor -%}
      </div>

      <div class="pt-sec-foot">{% render 'pagination', paginate: paginate %}</div>
    {%- endpaginate -%}
  </section>

{%- endif -%}

{% stylesheet %}
  .pt-coll-index { width: 100%; padding-top: 12px; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collections_grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Shop by ritual"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "All Collections"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:labels.subheading",
      "default": "Every world we've dreamed up, in one place — find the one that matches your mood."
    },
    {
      "type": "range",
      "id": "collections_per_page",
      "label": "t:labels.collections_per_page",
      "min": 12,
      "max": 48,
      "step": 4,
      "default": 24
    }
  ]
}
{% endschema %}

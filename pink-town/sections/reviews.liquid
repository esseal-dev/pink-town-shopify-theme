<section class="pt-section full-width" id="reviews">
  <div class="pt-sec-head pt-sec-head--center">
    <span class="pt-eyebrow">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
      {{ section.settings.eyebrow | escape }}
    </span>
    <h2 class="pt-h2">{{ section.settings.heading | escape }}</h2>
    <div class="pt-rating-line">
      <span class="pt-stars" aria-hidden="true">
        {%- for i in (1..5) -%}<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.4"><path d="M12 3.5l2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 17l-5.2 2.6 1-5.8L3.5 9.7l5.9-.9L12 3.5z" stroke-linejoin="round"/></svg>{%- endfor -%}
      </span>
      <strong>{{ section.settings.rating }}</strong>
      {{ 'sections.reviews.from_count' | t: count: section.settings.review_count }}
    </div>
  </div>

  <div class="pt-rev-stage">
    <button class="pt-rev-arrow pt-rev-arrow--prev" aria-label="{{ 'general.accessibility.prev' | t }}">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div class="pt-rev-track">
      {%- for block in section.blocks -%}
        <figure class="pt-rev" {{ block.shopify_attributes }}>
          <span class="pt-stars" aria-label="{{ block.settings.stars }} {{ 'sections.reviews.stars_label' | t }}">
            {%- for i in (1..5) -%}
              {%- if i <= block.settings.stars -%}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.4"><path d="M12 3.5l2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 17l-5.2 2.6 1-5.8L3.5 9.7l5.9-.9L12 3.5z" stroke-linejoin="round"/></svg>
              {%- else -%}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 3.5l2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 17l-5.2 2.6 1-5.8L3.5 9.7l5.9-.9L12 3.5z" stroke-linejoin="round"/></svg>
              {%- endif -%}
            {%- endfor -%}
          </span>
          <blockquote class="pt-rev-text">&ldquo;{{ block.settings.text | escape }}&rdquo;</blockquote>
          <figcaption class="pt-rev-by">
            <span class="pt-avatar" aria-hidden="true">{{ block.settings.name | slice: 0 }}</span>
            <span>
              <b>{{ block.settings.name | escape }}</b>
              <i>{{ block.settings.handle | escape }}</i>
            </span>
            <span class="pt-verified">{{ 'sections.reviews.verified' | t }}</span>
          </figcaption>
        </figure>
      {%- endfor -%}
    </div>
    <button class="pt-rev-arrow pt-rev-arrow--next" aria-label="{{ 'general.accessibility.next' | t }}">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  </div>
  {%- if section.blocks.size > 1 -%}
    <div class="pt-rev-dots" aria-hidden="true">
      {%- for block in section.blocks -%}
        <span class="pt-rev-dot{% if forloop.first %} is-on{% endif %}"></span>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .pt-rating-line { display: flex; align-items: center; gap: 9px; margin-top: 16px; font-size: 14px; color: var(--pt-ink-soft); font-family: var(--pt-font-body); }
  .pt-rating-line strong { color: var(--pt-ink); }
  .pt-rev-stage { position: relative; display: flex; align-items: center; gap: 20px; }
  .pt-rev-track { --rev-per-view: 3; --rev-gap: 18px; flex: 1; display: flex; gap: var(--rev-gap); overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth; scrollbar-width: none; -ms-overflow-style: none; }
  .pt-rev-track::-webkit-scrollbar { display: none; }
  .pt-rev { scroll-snap-align: start; flex: 0 0 calc((100% - (var(--rev-per-view) - 1) * var(--rev-gap)) / var(--rev-per-view)); background: var(--pt-card); border: 1px solid var(--pt-line); border-radius: var(--pt-radius); padding: 30px 28px; margin: 0; display: flex; flex-direction: column; gap: 18px; }
  .pt-rev-text { margin: 0; flex: 1; font-family: var(--pt-font-head); font-size: 19px; line-height: 1.48; color: var(--pt-ink); }
  .pt-rev-by { display: flex; align-items: center; gap: 11px; }
  .pt-avatar { width: 40px; height: 40px; border-radius: 50%; display: grid; place-items: center; background: var(--pt-accent-soft); color: var(--pt-accent-deep); font-family: var(--pt-font-head); font-size: 19px; font-weight: 600; flex: none; }
  .pt-rev-by b { font-size: 14px; display: block; font-family: var(--pt-font-body); }
  .pt-rev-by i { font-size: 12px; color: var(--pt-ink-faint); font-style: normal; font-family: var(--pt-font-body); display: block; }
  .pt-verified { margin-left: auto; font-size: 10.5px; font-weight: 700; letter-spacing: .04em; color: var(--pt-accent-deep); background: var(--pt-accent-soft); padding: 4px 9px; border-radius: 999px; white-space: nowrap; font-family: var(--pt-font-body); }
  .pt-rev-arrow { flex: none; width: 44px; height: 44px; border: 1px solid var(--pt-line); border-radius: 50%; background: #fff; cursor: pointer; display: grid; place-items: center; color: var(--pt-ink-soft); transition: border-color .2s, color .2s; padding: 0; }
  .pt-rev-arrow:hover { border-color: var(--pt-accent); color: var(--pt-accent-deep); }
  .pt-rev-dots { display: flex; gap: 8px; justify-content: center; margin-top: 24px; }
  .pt-rev-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--pt-line); transition: background .2s, transform .2s; }
  .pt-rev-dot.is-on { background: var(--pt-accent); transform: scale(1.3); }
  @media (max-width: 980px) {
    .pt-rev-track { --rev-per-view: 2; }
  }
  @media (max-width: 760px) {
    .pt-rev-track { --rev-per-view: 1; }
    .pt-rev-arrow { display: none; }
    .pt-rev { padding: 28px 24px; }
    .pt-rev-text { font-size: 18px; }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    const section = document.getElementById('reviews');
    if (!section) return;
    const track = section.querySelector('.pt-rev-track');
    const prev = section.querySelector('.pt-rev-arrow--prev');
    const next = section.querySelector('.pt-rev-arrow--next');
    const dots = section.querySelectorAll('.pt-rev-dot');
    const dotsWrap = section.querySelector('.pt-rev-dots');
    function step() {
      const card = track.firstElementChild;
      if (!card) return track.offsetWidth;
      const gap = parseFloat(getComputedStyle(track).columnGap) || 0;
      return card.offsetWidth + gap;
    }
    function slide(dir) {
      track.scrollBy({ left: dir * step(), behavior: 'smooth' });
    }
    function syncDots() {
      const idx = Math.round(track.scrollLeft / step());
      dots.forEach(function(d, i) { d.classList.toggle('is-on', i === idx); });
    }
    function syncControls() {
      const overflowing = track.scrollWidth > track.clientWidth + 1;
      if (prev) prev.hidden = !overflowing;
      if (next) next.hidden = !overflowing;
      if (dotsWrap) dotsWrap.hidden = !overflowing;
    }
    if (prev) prev.addEventListener('click', function() { slide(-1); });
    if (next) next.addEventListener('click', function() { slide(1); });
    track.addEventListener('scroll', syncDots, { passive: true });
    window.addEventListener('resize', syncControls);
    syncControls();
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.reviews.name",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "The reviews are in"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Worn & adored"
    },
    {
      "type": "text",
      "id": "rating",
      "label": "t:labels.rating",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "t:labels.review_count",
      "default": "12,400+"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "t:sections.reviews.blocks.review.name",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "t:labels.author_name",
          "default": "Mia R."
        },
        {
          "type": "text",
          "id": "handle",
          "label": "t:labels.author_handle",
          "default": "@miawears"
        },
        {
          "type": "range",
          "id": "stars",
          "label": "t:labels.stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:labels.text",
          "default": "Genuinely cannot believe these are under $30. The pearl drops look like the designer pair I saved for and never bought."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.reviews.name",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "name": "Mia R.",
            "handle": "@miawears",
            "stars": 5,
            "text": "Genuinely cannot believe these are under $30. The pearl drops look like the designer pair I saved for and never bought."
          }
        },
        {
          "type": "review",
          "settings": {
            "name": "Sofía L.",
            "handle": "@sof.jpg",
            "stars": 5,
            "text": "Wore the charm bracelet every single day for two months — showered, swam, the whole thing. Still sparkling. Obsessed."
          }
        },
        {
          "type": "review",
          "settings": {
            "name": "Hana K.",
            "handle": "@hanakoto",
            "stars": 5,
            "text": "Bought a stack for my little sister's birthday and now we're both hooked. Packaging is so cute it's gift-ready."
          }
        }
      ]
    }
  ]
}
{% endschema %}

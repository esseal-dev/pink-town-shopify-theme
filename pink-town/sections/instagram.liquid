<section class="pt-insta full-width" id="insta">
  <div class="pt-sec-head pt-sec-head--center">
    <span class="pt-eyebrow">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
      {{ section.settings.hashtag | escape }}
    </span>
    <h2 class="pt-h2">{{ section.settings.heading | escape }}</h2>
    <a href="https://instagram.com/{{ section.settings.handle | remove: '@' }}" class="pt-insta-handle" target="_blank" rel="noopener">@{{ section.settings.handle | remove: '@' | escape }}</a>
  </div>

  <div class="pt-insta-grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.url | default: '#' }}" class="pt-insta-tile" aria-label="{{ 'sections.instagram.view_post' | t }}" {{ block.shopify_attributes }} {% if block.settings.url != blank %}target="_blank" rel="noopener"{% endif %}>
        {%- if block.settings.image -%}
          {{ block.settings.image | image_url: width: 600 | image_tag: class: 'pt-ph-img', loading: 'lazy', alt: '' }}
        {%- else -%}
          <div style="position:absolute;inset:0;background:linear-gradient(135deg,var(--pt-accent-soft),var(--pt-bg-tint));"></div>
        {%- endif -%}
        <div class="pt-insta-over" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21C12 21 4 14.5 4 9.5C4 6.8 6.2 4.5 9 4.5C10.5 4.5 11.6 5.2 12 6.3C12.4 5.2 13.5 4.5 15 4.5C17.8 4.5 20 6.8 20 9.5C20 14.5 12 21 12 21Z"/></svg>
          {%- if block.settings.likes != blank -%}<span>{{ block.settings.likes | escape }}</span>{%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% stylesheet %}
  .pt-insta {
    background: radial-gradient(120% 80% at 50% 0%, var(--pt-accent-soft) 0%, transparent 60%), var(--pt-bg-tint);
    padding: 80px 32px;
    width: 100%;
  }
  .pt-insta > .pt-sec-head--center { max-width: var(--pt-wrap); margin: 0 auto 48px; }
  .pt-insta > .pt-insta-grid { max-width: var(--pt-wrap); margin: 0 auto; }
  .pt-insta-handle { display: inline-block; margin-top: 14px; font-weight: 700; color: var(--pt-accent-deep); font-size: 15px; font-family: var(--pt-font-body); }
  .pt-insta-handle:hover { text-decoration: underline; }
  .pt-insta-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 12px; }
  .pt-insta-tile { position: relative; border-radius: 14px; overflow: hidden; aspect-ratio: 1/1; display: block; }
  .pt-insta-over { position: absolute; inset: 0; z-index: 2; display: flex; align-items: center; justify-content: center; gap: 7px; color: #fff; font-weight: 800; background: rgba(120,55,72,.32); opacity: 0; transition: opacity .3s; font-family: var(--pt-font-body); }
  .pt-insta-tile:hover .pt-insta-over { opacity: 1; }
  @media (max-width: 980px) { .pt-insta-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 560px) { .pt-insta { padding: 60px 20px 0; } .pt-insta-grid { grid-template-columns: repeat(2, 1fr); } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.instagram.name",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "hashtag",
      "label": "t:labels.hashtag",
      "default": "#StyledByYou"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Tag us & get featured"
    },
    {
      "type": "text",
      "id": "handle",
      "label": "t:labels.instagram_handle",
      "default": "@yourstore"
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "t:sections.instagram.blocks.post.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        },
        {
          "type": "text",
          "id": "likes",
          "label": "t:labels.likes",
          "default": "2.4k"
        },
        {
          "type": "url",
          "id": "url",
          "label": "t:labels.url"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.instagram.name",
      "blocks": [
        { "type": "post", "settings": { "likes": "2.4k" } },
        { "type": "post", "settings": { "likes": "1.9k" } },
        { "type": "post", "settings": { "likes": "3.1k" } },
        { "type": "post", "settings": { "likes": "982" } },
        { "type": "post", "settings": { "likes": "4.6k" } },
        { "type": "post", "settings": { "likes": "1.2k" } }
      ]
    }
  ]
}
{% endschema %}

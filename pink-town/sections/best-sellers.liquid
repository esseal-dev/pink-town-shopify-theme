{%- liquid
  assign products_count = section.settings.products_count | default: 8
  assign has_products = false
  if section.settings.collection != blank and section.settings.collection.products.size > 0
    assign has_products = true
  endif
-%}

<section class="pt-bestsellers full-width" id="shop">
  <div class="pt-sec-head pt-sec-head--row">
    <div>
      <span class="pt-eyebrow">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
        {{ section.settings.eyebrow | escape }}
      </span>
      <h2 class="pt-h2">{{ section.settings.heading | escape }}</h2>
    </div>
    {%- if section.settings.filter_collections.size > 0 -%}
      <div class="pt-filters" role="group" aria-label="{{ 'sections.best_sellers.filter_label' | t }}">
        <button class="pt-chip" data-filter="" data-on="1">{{ 'sections.best_sellers.filter_all' | t }}</button>
        {%- for filter_collection in section.settings.filter_collections -%}
          <button class="pt-chip" data-filter="{{ filter_collection.handle }}" data-on="0">{{ filter_collection.title | escape }}</button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <div class="pt-prod-grid" data-filterable>
    {%- if has_products -%}
      {%- for product in section.settings.collection.products limit: products_count -%}
        {%- liquid
          assign variant = product.first_available_variant
          assign on_sale = false
          if product.compare_at_price > product.price
            assign on_sale = true
          endif
          assign savings_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price
          capture product_cats
            for product_collection in product.collections
              echo product_collection.handle
              unless forloop.last
                echo ' '
              endunless
            endfor
          endcapture
        -%}

        <div class="pt-card" data-cat="{{ product_cats }}">
          <div class="pt-card-media">
            <div class="pt-ph">
              {%- if product.featured_image -%}
                {{ product.featured_image | image_url: width: 600 | image_tag: class: 'pt-ph-img', loading: 'lazy', alt: product.featured_image.alt | default: product.title }}
              {%- endif -%}
            </div>
            {%- if product.tags contains 'bestseller' or product.tags contains 'Bestseller' -%}
              <span class="pt-card-tag">{{ 'products.tag_bestseller' | t }}</span>
            {%- elsif product.tags contains 'new' or product.tags contains 'New' -%}
              <span class="pt-card-tag">{{ 'products.tag_new' | t }}</span>
            {%- endif -%}
            <button class="pt-wish pt-wish-btn" data-product-handle="{{ product.handle }}" data-on="0" aria-label="{{ 'products.save_to_wishlist' | t }}">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                <path d="M12 21C12 21 4 14.5 4 9.5C4 6.8 6.2 4.5 9 4.5C10.5 4.5 11.6 5.2 12 6.3C12.4 5.2 13.5 4.5 15 4.5C17.8 4.5 20 6.8 20 9.5C20 14.5 12 21 12 21Z" stroke-linejoin="round"/>
              </svg>
            </button>
            {%- if variant.available -%}
              <button class="pt-add pt-add-btn"
                      data-variant-id="{{ variant.id }}"
                      data-product-title="{{ product.title | escape }}">
                {{ 'products.add_to_cart' | t }}
              </button>
            {%- else -%}
              <span class="pt-add pt-add--soldout">{{ 'products.sold_out' | t }}</span>
            {%- endif -%}
          </div>
          <div class="pt-card-info">
            <span class="pt-card-cat">{{ product.type | escape }}</span>
            <h3 class="pt-card-name"><a href="{{ product.url }}">{{ product.title | escape }}</a></h3>
            <div class="pt-card-price">
              <span class="pt-price-now">{{ product.price | money }}</span>
              {%- if on_sale -%}
                <span class="pt-price-was">{{ product.compare_at_price | money }}</span>
                <span class="pt-price-save">{{ 'products.save_pct' | t: pct: savings_pct }}</span>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- else -%}
      {%- for j in (1..products_count) -%}
        {%- liquid
          assign demo_idx = forloop.index | modulo: 8
          if demo_idx == 0
            assign demo_idx = 8
          endif
          assign price_idx = forloop.index | modulo: 4
          if price_idx == 0
            assign price_idx = 4
          endif
          case price_idx
            when 1
              assign demo_pct = 65
            when 2
              assign demo_pct = 65
            when 3
              assign demo_pct = 66
            else
              assign demo_pct = 63
          endcase
          assign demo_name_key = 'sections.best_sellers.onboarding_name_' | append: demo_idx
          assign demo_cat_key = 'sections.best_sellers.onboarding_category_' | append: demo_idx
          assign demo_price_key = 'sections.best_sellers.onboarding_price_' | append: price_idx
          assign demo_was_key = 'sections.best_sellers.onboarding_was_' | append: price_idx
        -%}
        <div class="pt-card" data-cat="">
          <div class="pt-card-media">
            <div class="pt-ph" style="--ph-tint: {% cycle '#f6dde4', '#f8e0ea', '#e9e1f2', '#f7e1d9' %};"></div>
            {%- if demo_idx == 1 or demo_idx == 6 -%}
              <span class="pt-card-tag">{{ 'products.tag_bestseller' | t }}</span>
            {%- elsif demo_idx == 2 or demo_idx == 7 -%}
              <span class="pt-card-tag">{{ 'products.tag_new' | t }}</span>
            {%- endif -%}
            <button class="pt-wish pt-wish-btn" data-on="0" aria-label="{{ 'products.save_to_wishlist' | t }}">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                <path d="M12 21C12 21 4 14.5 4 9.5C4 6.8 6.2 4.5 9 4.5C10.5 4.5 11.6 5.2 12 6.3C12.4 5.2 13.5 4.5 15 4.5C17.8 4.5 20 6.8 20 9.5C20 14.5 12 21 12 21Z" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
          <div class="pt-card-info">
            <span class="pt-card-cat">{{ demo_cat_key | t }}</span>
            <h3 class="pt-card-name">{{ demo_name_key | t }}</h3>
            <div class="pt-card-price">
              <span class="pt-price-now">{{ demo_price_key | t }}</span>
              <span class="pt-price-was">{{ demo_was_key | t }}</span>
              <span class="pt-price-save">{{ 'products.save_pct' | t: pct: demo_pct }}</span>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  <div class="pt-sec-foot">
    <a href="{{ section.settings.view_all_url | default: '/collections/all' }}" class="pt-btn pt-btn--ghost">{{ section.settings.view_all_text | escape }}</a>
  </div>
</section>

{% stylesheet %}
  .pt-bestsellers {
    background: radial-gradient(120% 80% at 50% 0%, var(--pt-accent-soft) 0%, transparent 60%), var(--pt-bg-tint);
    padding: 92px 32px;
    width: 100%;
  }
  .pt-bestsellers > * { max-width: var(--pt-wrap); margin-left: auto; margin-right: auto; }
  .pt-filters { display: flex; gap: 8px; flex-wrap: wrap; }
  .pt-chip { font-family: var(--pt-font-body); font-size: 13px; font-weight: 600; color: var(--pt-ink-soft); background: #fff; border: 1px solid var(--pt-line); padding: 9px 16px; border-radius: 999px; cursor: pointer; transition: all .2s; }
  .pt-chip:hover { border-color: var(--pt-accent); color: var(--pt-accent-deep); }
  .pt-chip[data-on="1"] { background: var(--pt-accent-deep); color: #fff; border-color: var(--pt-accent-deep); }
  .pt-prod-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 26px 22px; }
  .pt-card { position: relative; }
  .pt-card-media { position: relative; border-radius: var(--pt-radius); overflow: hidden; aspect-ratio: 1/1; box-shadow: var(--pt-shadow-sm); }
  .pt-card-media .pt-ph {
    height: 100%;
    background:
      repeating-linear-gradient(135deg, rgba(255,255,255,.55) 0 20px, transparent 20px 44px),
      var(--ph-tint, #f6dde4);
  }
  .pt-card-media .pt-ph-lbl { font-weight: 700; padding: 9px 18px; font-family: var(--pt-font-body); color: var(--pt-ink-soft); box-shadow: var(--pt-shadow-sm); }
  .pt-card-tag { position: absolute; top: 12px; left: 12px; z-index: 3; background: rgba(255,255,255,.94); color: var(--pt-accent-deep); font-size: 10.5px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; padding: 5px 10px; border-radius: 999px; font-family: var(--pt-font-body); }
  .pt-wish { position: absolute; top: 10px; right: 10px; z-index: 3; width: 34px; height: 34px; border: none; display: grid; place-items: center; background: rgba(255,255,255,.9); color: var(--pt-ink-soft); border-radius: 50%; cursor: pointer; transition: color .2s, transform .2s, background .2s; }
  .pt-wish:hover { transform: scale(1.1); }
  .pt-wish[data-on="1"] { color: var(--pt-accent); background: #fff; }
  .pt-add { position: absolute; left: 12px; right: 12px; bottom: 12px; z-index: 3; border: none; background: rgba(255,255,255,.96); color: var(--pt-ink); font-family: var(--pt-font-body); font-weight: 700; font-size: 13px; padding: 12px; border-radius: 999px; cursor: pointer; box-shadow: var(--pt-shadow-sm); opacity: 0; transform: translateY(12px); transition: opacity .3s, transform .3s, background .25s, color .25s; text-align: center; }
  .pt-card-media:hover .pt-add { opacity: 1; transform: translateY(0); }
  .pt-add:hover { background: linear-gradient(135deg, var(--pt-accent), var(--pt-accent-deep)); color: #fff; }
  .pt-add.is-added { opacity: 1; transform: translateY(0); background: var(--pt-accent-deep); color: #fff; }
  .pt-add--soldout { opacity: 1; transform: none; background: rgba(255,255,255,.8); color: var(--pt-ink-faint); cursor: default; }
  @media (hover: none) { .pt-add { opacity: 1; transform: none; } }
  .pt-card-info { padding: 15px 2px 0; }
  .pt-card-cat { font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--pt-ink-faint); font-family: var(--pt-font-body); }
  .pt-card-name { font-family: var(--pt-font-head); font-size: 20px; margin: 3px 0 8px; line-height: 1.1; }
  .pt-card-name a { color: inherit; }
  .pt-card-name a:hover { color: var(--pt-accent-deep); }
  .pt-card-price { display: flex; align-items: center; gap: 9px; flex-wrap: wrap; }
  .pt-price-now { font-weight: 800; font-size: 15px; color: var(--pt-ink); font-family: var(--pt-font-body); }
  .pt-price-was { font-size: 13px; color: var(--pt-ink-faint); text-decoration: line-through; font-family: var(--pt-font-body); }
  .pt-price-save { margin-left: auto; font-size: 11px; font-weight: 800; color: var(--pt-accent-deep); background: var(--pt-accent-soft); padding: 3px 8px; border-radius: 999px; white-space: nowrap; font-family: var(--pt-font-body); }
  @media (max-width: 980px) { .pt-prod-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 760px) {
    .pt-bestsellers { padding: 60px 20px; }
    .pt-prod-grid { grid-template-columns: repeat(2, 1fr); gap: 20px 14px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.best_sellers.name",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Loved by thousands"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Best sellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:labels.collection"
    },
    {
      "type": "collection_list",
      "id": "filter_collections",
      "label": "t:labels.filter_collections",
      "limit": 5
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "t:labels.products_count",
      "min": 4,
      "max": 12,
      "step": 4,
      "default": 8
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "t:labels.view_all_text",
      "default": "View all jewelry"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "t:labels.view_all_url"
    }
  ],
  "presets": [
    {
      "name": "t:sections.best_sellers.name"
    }
  ]
}
{% endschema %}

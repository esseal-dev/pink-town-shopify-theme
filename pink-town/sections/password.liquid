{% comment %}
  This section is used in the password template to render landing page shown
  when password protection is applied to a store.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/password
{% endcomment %}

<div class="pt-pw">
  <div class="pt-pw-glow"></div>
  <div class="pt-pw-card">
    <a href="{{ routes.root_url }}" class="pt-logo pt-pw-logo">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="var(--pt-accent)" style="margin-right:2px" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
      {{ shop.name }}
    </a>

    <span class="pt-eyebrow">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
      {{ section.settings.eyebrow | escape }}
    </span>
    <h1 class="pt-pw-h">{{ section.settings.heading | escape }}</h1>
    <p class="pt-pw-sub">
      {%- if shop.password_message != blank -%}
        {{ shop.password_message }}
      {%- else -%}
        {{ section.settings.subheading | escape }}
      {%- endif -%}
    </p>

    {%- form 'storefront_password', class: 'pt-pw-form' -%}
      {%- if form.errors -%}
        <div class="pt-contact-error">{{ form.errors | default_errors }}</div>
      {%- endif -%}
      <label class="pt-pw-fld">
        <span class="pt-fld-lbl">{{ 'password.password' | t }}</span>
        <input class="pt-input" type="password" name="password" id="password-input" autocomplete="current-password" autofocus>
      </label>
      <button type="submit" class="pt-btn pt-btn--solid pt-btn--full">{{ 'password.enter' | t }}</button>
    {%- endform -%}

    {%- if section.settings.instagram_url != blank or section.settings.tiktok_url != blank or section.settings.pinterest_url != blank -%}
      <div class="pt-socials pt-pw-socials">
        {%- if section.settings.instagram_url != blank -%}
          <a href="{{ section.settings.instagram_url }}" class="pt-social" target="_blank" rel="noopener">Instagram</a>
        {%- endif -%}
        {%- if section.settings.tiktok_url != blank -%}
          <a href="{{ section.settings.tiktok_url }}" class="pt-social" target="_blank" rel="noopener">TikTok</a>
        {%- endif -%}
        {%- if section.settings.pinterest_url != blank -%}
          <a href="{{ section.settings.pinterest_url }}" class="pt-social" target="_blank" rel="noopener">Pinterest</a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  <a href="/admin" class="pt-pw-admin">{{ 'sections.password.admin_link' | t }}</a>
</div>

{% stylesheet %}
  .pt-pw { position: relative; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 32px; overflow: hidden; font-family: var(--pt-font-body); }
  .pt-pw-glow { position: absolute; width: 620px; height: 620px; border-radius: 50%; top: -220px; left: 50%; transform: translateX(-50%); background: radial-gradient(circle, var(--pt-accent-soft), transparent 70%); filter: blur(20px); pointer-events: none; }
  .pt-pw-card { position: relative; z-index: 1; width: 100%; max-width: 420px; background: #fff; border: 1px solid var(--pt-line); border-radius: calc(var(--pt-radius) + 6px); box-shadow: var(--pt-shadow-md); padding: 44px 36px; text-align: center; display: flex; flex-direction: column; align-items: center; }
  .pt-pw-logo { margin-bottom: 22px; }
  .pt-pw-h { font-family: var(--pt-font-head); font-size: clamp(1.8rem, 4vw, 2.3rem); margin: 14px 0 0; }
  .pt-pw-sub { color: var(--pt-ink-soft); font-size: 14.5px; line-height: 1.6; margin: 14px 0 0; }
  .pt-pw-form { width: 100%; margin-top: 26px; display: flex; flex-direction: column; gap: 14px; }
  .pt-pw-fld { display: flex; flex-direction: column; gap: 8px; text-align: left; }
  .pt-pw-socials { margin-top: 26px; justify-content: center; }
  .pt-pw-admin { position: relative; z-index: 1; margin-top: 24px; font-size: 12.5px; color: var(--pt-ink-faint); }
  .pt-pw-admin:hover { color: var(--pt-accent-deep); text-decoration: underline; }
  @media (max-width: 480px) {
    .pt-pw-card { padding: 36px 24px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.password",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Coming soon"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Something sparkly is on its way"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:labels.subheading",
      "default": "We're putting the finishing touches on our new store. Enter the password below if you've got early access."
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "t:labels.instagram_url"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "t:labels.tiktok_url"
    },
    {
      "type": "url",
      "id": "pinterest_url",
      "label": "t:labels.pinterest_url"
    }
  ]
}
{% endschema %}

<section class="pt-section pt-faq-cta">
  <span class="pt-eyebrow">
    <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
    {{ section.settings.eyebrow | escape }}
  </span>
  <h2 class="pt-h2">{{ section.settings.heading | escape }}</h2>
  {%- if section.settings.text != blank -%}
    <p>{{ section.settings.text | escape }}</p>
  {%- endif -%}
  <a href="{{ section.settings.button_url | default: '/pages/contact' }}" class="pt-btn pt-btn--solid">{{ section.settings.button_text | escape }}</a>
</section>

{% stylesheet %}
  .pt-faq-cta { max-width: 640px; text-align: center; display: flex; flex-direction: column; align-items: center; font-family: var(--pt-font-body); }
  .pt-faq-cta p { color: var(--pt-ink-soft); font-size: 15px; line-height: 1.6; margin: 14px 0 28px; max-width: 46ch; }
  .pt-faq-cta .pt-h2 { margin-bottom: 0; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.faq.cta_name",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Still stuck?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "We're just a message away"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "t:labels.text",
      "default": "Our team typically replies within a few hours — reach out and we'll sort you out."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:labels.button_text",
      "default": "Contact us"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:labels.url"
    }

  ],
  "presets": [
    {
      "name": "t:sections.faq.cta_name"
    }
  ]
}
{% endschema %}

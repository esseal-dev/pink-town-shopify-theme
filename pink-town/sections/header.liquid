<header class="pt-nav full-width" data-scrolled="0">
  <nav class="pt-nav-inner">
    <button type="button" class="pt-nav-hamburger" data-nav-open aria-label="{{ 'general.accessibility.open_menu' | t }}" aria-expanded="false">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round"/></svg>
    </button>

    <ul class="pt-nav-links pt-nav-left" aria-label="{{ 'general.accessibility.nav_left' | t }}">
      {%- assign left_count = 0 -%}
      {%- for link in section.settings.menu.links -%}
        {%- if left_count < 3 -%}
          {%- render 'nav-menu-item', link: link, context: 'desktop', depth: 0 -%}
          {%- assign left_count = left_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </ul>

    <a href="{{ routes.root_url }}" class="pt-logo" aria-label="{{ shop.name }}">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="var(--pt-accent)" style="margin-right:2px" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
      <span>{{ shop.name }}</span>
    </a>

    <ul class="pt-nav-links pt-nav-right" aria-label="{{ 'general.accessibility.nav_right' | t }}">
      {%- assign right_start = 3 -%}
      {%- assign right_shown = 0 -%}
      {%- for link in section.settings.menu.links -%}
        {%- if forloop.index0 >= right_start and right_shown < 2 -%}
          {%- render 'nav-menu-item', link: link, context: 'desktop', depth: 0 -%}
          {%- assign right_shown = right_shown | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}

      <li>
        <a href="{{ routes.search_url }}" class="pt-iconbtn pt-nav-search" data-search-open aria-label="{{ 'general.accessibility.search' | t }}">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3" stroke-linecap="round"/></svg>
        </a>
      </li>

      {% if shop.customer_accounts_enabled %}
        <li>
          <shopify-account{% if section.settings.customer_account_menu != blank %} menu="{{ section.settings.customer_account_menu }}"{% endif %}>
            <button class="pt-iconbtn" aria-label="{{ 'general.accessibility.account' | t }}">
              {{ 'icon-account.svg' | inline_asset_content }}
            </button>
          </shopify-account>
        </li>
      {% endif %}

      <li>
        <button class="pt-iconbtn pt-nav-cart" aria-label="{{ 'cart.title' | t }}">
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <path d="M6 8h12l-1 12H7L6 8z" stroke-linejoin="round"/>
            <path d="M9 8a3 3 0 0 1 6 0"/>
          </svg>
          <span class="pt-badge pt-nav-cart-badge"{% unless cart.item_count > 0 %} style="display:none"{% endunless %} aria-label="{{ cart.item_count }} items">{{ cart.item_count }}</span>
        </button>
      </li>
    </ul>
  </nav>
</header>

<div class="pt-nav-scrim" data-nav-scrim aria-hidden="true"></div>

<aside class="pt-nav-drawer" data-nav-drawer aria-hidden="true" inert aria-label="{{ 'general.accessibility.menu' | t }}">
  <div class="pt-nav-drawer-head">
    <a href="{{ routes.root_url }}" class="pt-logo">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="var(--pt-accent)" style="margin-right:2px" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
      {{ shop.name }}
    </a>
    <button type="button" class="pt-drawer-x" data-nav-close aria-label="{{ 'general.accessibility.close' | t }}">✕</button>
  </div>
  <nav class="pt-nav-drawer-links" aria-label="{{ 'general.accessibility.nav_left' | t }}">
    {%- for link in section.settings.menu.links -%}
      {%- render 'nav-menu-item', link: link, context: 'mobile', depth: 0 -%}
    {%- endfor -%}
  </nav>
</aside>

<div class="pt-search-overlay" data-search-overlay aria-hidden="true" inert>
  <div class="pt-search-panel">
    <form action="{{ routes.search_url }}" method="get" role="search" class="pt-search-form">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3" stroke-linecap="round"/></svg>
      <input type="search" name="q" class="pt-search-input" data-search-input
             placeholder="{{ 'search.placeholder' | t }}" autocomplete="off" autocorrect="off"
             aria-label="{{ 'general.accessibility.search' | t }}">
      <input type="hidden" name="options[prefix]" value="last">
      <button type="submit" class="pt-btn pt-btn--solid pt-search-submit">{{ 'search.submit' | t }}</button>
      <button type="button" class="pt-drawer-x" data-search-close aria-label="{{ 'general.accessibility.close' | t }}">✕</button>
    </form>
    <div class="pt-search-live" data-search-results data-url="{{ routes.predictive_search_url }}" aria-live="polite"></div>
  </div>
</div>

<div class="pt-scrim" aria-hidden="true"></div>

<aside class="pt-drawer" aria-hidden="true" inert aria-label="{{ 'cart.title' | t }}"
       data-root-url="{{ routes.root_url }}" data-cart-url="{{ routes.cart_url }}">
  <div class="pt-drawer-head">
    <h3>{{ 'cart.your_bag' | t }} <span class="pt-drawer-count">({{ cart.item_count }})</span></h3>
    <button class="pt-drawer-x" aria-label="{{ 'general.accessibility.close' | t }}">✕</button>
  </div>

  <div class="pt-drawer-empty"{% if cart.item_count > 0 %} style="display:none"{% endif %}>
    <svg width="26" height="26" viewBox="0 0 24 24" fill="var(--pt-accent)" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
    <p>{{ 'cart.empty_message' | t }}</p>
    <button class="pt-btn pt-btn--solid">{{ 'cart.start_shopping' | t }}</button>
  </div>

  {%- assign drawer_free_ship = settings.free_shipping_threshold | default: 0 | times: 100 -%}
  {%- if drawer_free_ship > 0 -%}
    <div class="pt-ship"{% unless cart.item_count > 0 %} style="display:none"{% endunless %}
         data-free-ship-cents="{{ drawer_free_ship }}"
         data-i-remaining-html="{{ 'cart.free_ship_remaining_html' | t: amount: '%%AMOUNT%%' | escape }}"
         data-i-unlocked-html="{{ 'cart.free_ship_unlocked_html' | t | escape }}">
      <p class="pt-ship-msg"></p>
      <div class="pt-ship-bar"><i style="width:0%"></i></div>
    </div>
  {%- endif -%}

  <div class="pt-drawer-items"{% unless cart.item_count > 0 %} style="display:none"{% endunless %}>
    {% for item in cart.items %}
      <div class="pt-line" data-line="{{ forloop.index }}">
        <div class="pt-ph" style="width:64px;flex:none;border-radius:12px;aspect-ratio:1/1;background:#f6dde4;overflow:hidden;">
          {% if item.image %}
            {{ item.image | image_url: width: 128 | image_tag: width: 64, height: 64, loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;' }}
          {% endif %}
        </div>
        <div class="pt-line-mid">
          {% unless item.variant.title == 'Default Title' %}
            <span class="pt-line-cat">{{ item.variant.title | escape }}</span>
          {% endunless %}
          <b class="pt-line-name">{{ item.title | escape }}</b>
          <div class="pt-qty">
            <button type="button" onclick="ptChangeQty({{ forloop.index }},{{ item.quantity | minus: 1 }})" aria-label="{{ 'cart.decrease' | t }}">−</button>
            <span>{{ item.quantity }}</span>
            <button type="button" onclick="ptChangeQty({{ forloop.index }},{{ item.quantity | plus: 1 }})" aria-label="{{ 'cart.increase' | t }}">+</button>
          </div>
        </div>
        <div class="pt-line-end">
          <b>{{ item.final_line_price | money }}</b>
          <button class="pt-line-rm" type="button" onclick="ptChangeQty({{ forloop.index }},0)">{{ 'cart.remove' | t }}</button>
        </div>
      </div>
    {% endfor %}

    <div class="pt-cart-extras">
      <form id="pt-promo-form" class="pt-promo-wrap" data-drawer-promo-form>
        <div class="pt-promo-row">
          <input class="pt-promo-input" type="text" name="discount" placeholder="{{ 'cart.promo_placeholder' | t }}" aria-label="{{ 'cart.promo_code' | t }}" />
          <button type="submit" class="pt-promo-btn">{{ 'cart.apply' | t }}</button>
        </div>
      </form>
    </div>
  </div>

  <div class="pt-drawer-foot"{% unless cart.item_count > 0 %} style="display:none"{% endunless %}>
    <div class="pt-drawer-sub">
      <span>{{ 'cart.total' | t }}</span>
      <b>{{ cart.total_price | money }}</b>
    </div>
    <a href="{{ routes.cart_url }}/checkout" class="pt-btn pt-btn--solid pt-btn--full pt-checkout-btn">
      {{ 'cart.checkout' | t }} &middot; {{ cart.total_price | money }}
    </a>
    <span class="pt-drawer-note">{{ 'cart.secure_note' | t }}</span>
  </div>
</aside>

<div class="pt-toast" role="status" aria-live="polite">
  <svg width="13" height="13" viewBox="0 0 24 24" fill="var(--pt-accent)" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
  <span class="pt-toast-msg"></span>
  <button onclick="ptOpenCart();this.closest('.pt-toast').classList.remove('is-on')">{{ 'cart.view_bag' | t }}</button>
</div>

{% stylesheet %}
  .pt-nav {
    position: sticky; top: 0; z-index: 40;
    transition: background .3s, box-shadow .3s, border-color .3s;
    border-bottom: 1px solid transparent;
    background: rgba(255,250,251,.7);
    backdrop-filter: blur(14px) saturate(150%);
    font-family: var(--pt-font-body);
  }
  .pt-nav[data-scrolled="1"] { background: rgba(255,250,251,.92); box-shadow: var(--pt-shadow-sm); border-color: var(--pt-line); }
  .pt-nav-inner { max-width: var(--pt-wrap); margin: 0 auto; padding: 0 32px; height: 72px; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; }
  .pt-nav-links { display: flex; align-items: center; gap: 26px; }
  .pt-nav-right { justify-content: flex-end; gap: 18px; }
  .pt-nav-item { position: relative; display: flex; align-items: center; }
  .pt-navlink { font-size: 13.5px; font-weight: 600; color: var(--pt-ink); position: relative; padding: 4px 0; display: inline-flex; align-items: center; gap: 5px; }
  .pt-navlink::after { content: ''; position: absolute; left: 0; bottom: -2px; height: 1.5px; width: 0; background: var(--pt-accent); transition: width .28s ease; }
  .pt-navlink:hover { color: var(--pt-accent-deep); }
  .pt-navlink:hover::after { width: 100%; }
  .pt-nav-caret { flex: none; transition: transform .2s; color: var(--pt-ink-faint); }
  .pt-nav-item--parent:hover > .pt-navlink .pt-nav-caret,
  .pt-nav-item--parent:focus-within > .pt-navlink .pt-nav-caret { transform: rotate(180deg); color: var(--pt-accent-deep); }

  /* Desktop dropdown flyouts (nested to any depth) */
  .pt-nav-dropdown {
    position: absolute; top: 100%; left: 0; z-index: 50;
    min-width: 200px; margin-top: 10px; padding: 8px;
    background: #fff; border: 1px solid var(--pt-line); border-radius: 14px; box-shadow: var(--pt-shadow-md);
    opacity: 0; visibility: hidden; transform: translateY(6px);
    transition: opacity .2s ease, transform .2s ease, visibility .2s;
    list-style: none;
  }
  .pt-nav-item--parent:hover > .pt-nav-dropdown,
  .pt-nav-item--parent:focus-within > .pt-nav-dropdown { opacity: 1; visibility: visible; transform: translateY(0); }
  .pt-nav-dropdown .pt-nav-item { display: block; width: 100%; }
  .pt-nav-dropdown .pt-navlink { width: 100%; padding: 9px 12px; border-radius: 9px; font-weight: 500; }
  .pt-nav-dropdown .pt-navlink:hover { background: var(--pt-accent-soft); color: var(--pt-accent-deep); }
  .pt-nav-dropdown .pt-navlink::after { display: none; }
  .pt-nav-dropdown .pt-nav-dropdown { top: -8px; left: calc(100% + 6px); margin-top: 0; }
  .pt-logo { font-family: var(--pt-font-head); font-size: 27px; font-weight: 600; letter-spacing: .01em; display: inline-flex; align-items: center; color: var(--pt-ink); }
  .pt-iconbtn { position: relative; display: grid; place-items: center; width: 38px; height: 38px; border: none; background: transparent; color: var(--pt-ink); border-radius: 50%; cursor: pointer; transition: background .2s, color .2s; }
  .pt-iconbtn:hover { background: var(--pt-accent-soft); color: var(--pt-accent-deep); }
  .pt-badge { position: absolute; top: 2px; right: 0; min-width: 17px; height: 17px; padding: 0 4px; display: grid; place-items: center; font-size: 10px; font-weight: 800; color: #fff; background: var(--pt-accent); border-radius: 999px; border: 2px solid var(--pt-bg); }
  /* Mobile nav hamburger + drawer */
  .pt-nav-hamburger { display: none; width: 100%; height: 38px; border: none; background: transparent; color: var(--pt-ink); cursor: pointer; align-items: center; justify-content: flex-start; transition: background .2s; }
  .pt-nav-hamburger svg { flex: none; width: 38px; height: 38px; padding: 9px; box-sizing: border-box; border-radius: 50%; transition: background .2s; }
  .pt-nav-hamburger:hover svg { background: var(--pt-accent-soft); }
  .pt-nav-scrim { position: fixed; inset: 0; z-index: 95; background: rgba(70,38,48,.34); opacity: 0; pointer-events: none; transition: opacity .35s; backdrop-filter: blur(2px); }
  .pt-nav-scrim.is-open { opacity: 1; pointer-events: auto; }
  .pt-nav-drawer { position: fixed; top: 0; left: 0; z-index: 101; width: min(320px, 84vw); height: 100%; background: var(--pt-bg); box-shadow: 20px 0 60px -30px rgba(70,38,48,.5); transform: translateX(-100%); transition: transform .4s cubic-bezier(.3,.7,.4,1); display: flex; flex-direction: column; font-family: var(--pt-font-body); }
  .pt-nav-drawer.is-open { transform: translateX(0); }
  .pt-nav-drawer-head { display: flex; align-items: center; justify-content: space-between; padding: 20px 20px; border-bottom: 1px solid var(--pt-line); }
  .pt-nav-drawer-links { display: flex; flex-direction: column; padding: 10px 10px; overflow-y: auto; }
  .pt-nav-drawer-link { padding: 15px 14px; font-size: 15.5px; font-weight: 600; color: var(--pt-ink); border-radius: 12px; transition: background .2s, color .2s; flex: 1; }
  .pt-nav-drawer-link:hover, .pt-nav-drawer-link:active { background: var(--pt-accent-soft); color: var(--pt-accent-deep); }
  .pt-nav-drawer-link--sub { font-size: 14.5px; font-weight: 500; padding-left: calc(14px + var(--depth, 1) * 16px); }

  .pt-nav-drawer-group-head { display: flex; align-items: stretch; }
  .pt-nav-drawer-toggle { flex: none; width: 46px; border: none; background: transparent; color: var(--pt-ink-soft); cursor: pointer; border-radius: 12px; display: grid; place-items: center; transition: background .2s, color .2s; }
  .pt-nav-drawer-toggle:hover { background: var(--pt-accent-soft); color: var(--pt-accent-deep); }
  .pt-nav-drawer-toggle svg { transition: transform .25s; }
  .pt-nav-drawer-group[data-open="1"] > .pt-nav-drawer-group-head .pt-nav-drawer-toggle svg { transform: rotate(180deg); }
  .pt-nav-drawer-sub-wrap { display: grid; grid-template-rows: 0fr; transition: grid-template-rows .3s ease; }
  .pt-nav-drawer-group[data-open="1"] > .pt-nav-drawer-sub-wrap { grid-template-rows: 1fr; }
  .pt-nav-drawer-sub-inner { overflow: hidden; }
  .pt-nav-drawer-sub { display: flex; flex-direction: column; padding-bottom: 4px; }
  /* Cart scrim */
  .pt-scrim { position: fixed; inset: 0; z-index: 90; background: rgba(70,38,48,.34); opacity: 0; pointer-events: none; transition: opacity .35s; backdrop-filter: blur(2px); }
  .pt-scrim.is-open { opacity: 1; pointer-events: auto; }
  /* Cart drawer */
  .pt-drawer { position: fixed; top: 0; right: 0; z-index: 100; width: min(420px, 92vw); height: 100%; background: var(--pt-bg); box-shadow: -20px 0 60px -30px rgba(70,38,48,.5); transform: translateX(100%); transition: transform .4s cubic-bezier(.3,.7,.4,1); display: flex; flex-direction: column; font-family: var(--pt-font-body); }
  .pt-drawer.is-open { transform: translateX(0); }
  .pt-drawer-head { display: flex; align-items: center; justify-content: space-between; padding: 24px 26px; border-bottom: 1px solid var(--pt-line); }
  .pt-drawer-head h3 { font-family: var(--pt-font-head); font-size: 24px; margin: 0; }
  .pt-drawer-head span { color: var(--pt-ink-faint); font-size: 16px; }
  .pt-drawer-x { border: none; background: transparent; font-size: 17px; color: var(--pt-ink-soft); cursor: pointer; width: 34px; height: 34px; border-radius: 50%; transition: background .2s; }
  .pt-drawer-x:hover { background: var(--pt-accent-soft); }
  .pt-drawer-empty { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px; color: var(--pt-ink-soft); padding: 40px; text-align: center; }
  .pt-drawer-items { flex: 1; overflow-y: auto; padding: 8px 26px; }
  .pt-line { display: flex; gap: 14px; padding: 18px 0; border-bottom: 1px solid var(--pt-line); }
  .pt-line-mid { flex: 1; min-width: 0; }
  .pt-line-cat { font-size: 10.5px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--pt-ink-faint); display: block; }
  .pt-line-name { font-family: var(--pt-font-head); font-size: 18px; display: block; margin: 2px 0 10px; line-height: 1.15; }
  .pt-qty { display: inline-flex; align-items: center; border: 1px solid var(--pt-line); border-radius: 999px; }
  .pt-qty button { width: 28px; height: 28px; border: none; background: transparent; font-size: 16px; color: var(--pt-ink); cursor: pointer; border-radius: 50%; }
  .pt-qty button:hover { color: var(--pt-accent-deep); }
  .pt-qty span { min-width: 26px; text-align: center; font-size: 14px; font-weight: 700; }
  .pt-line-end { text-align: right; display: flex; flex-direction: column; justify-content: space-between; align-items: flex-end; }
  .pt-line-end b { font-size: 15px; }
  .pt-line-rm { border: none; background: transparent; color: var(--pt-ink-faint); font-size: 11.5px; cursor: pointer; font-family: var(--pt-font-body); padding: 0; transition: color .2s; }
  .pt-line-rm:hover { color: var(--pt-accent-deep); text-decoration: underline; }
  /* Free shipping bar */
  .pt-ship { padding: 14px 26px 16px; border-bottom: 1px solid var(--pt-line); }
  .pt-ship-msg { margin: 0 0 9px; font-size: 13px; color: var(--pt-ink-soft); }
  .pt-ship-msg b { color: var(--pt-accent-deep); font-weight: 800; }
  .pt-ship-bar { height: 7px; border-radius: 999px; background: var(--pt-accent-soft); overflow: hidden; }
  .pt-ship-bar i { display: block; height: 100%; border-radius: 999px; background: linear-gradient(90deg, var(--pt-accent), var(--pt-accent-deep)); transition: width .4s cubic-bezier(.3,.7,.4,1); }
  /* Cart extras */
  .pt-cart-extras { padding: 16px 0 4px; }
  .pt-promo-wrap { margin-top: 12px; }
  .pt-promo-row { display: flex; gap: 8px; }
  .pt-promo-input { flex: 1; min-width: 0; font-family: var(--pt-font-body); font-size: 13px; padding: 10px 14px; border: 1px solid var(--pt-line); border-radius: 999px; background: #fff; outline: none; transition: border-color .2s; }
  .pt-promo-input:focus { border-color: var(--pt-accent); }
  .pt-promo-btn { flex: none; border: 1px solid var(--pt-accent); background: #fff; color: var(--pt-accent-deep); font-family: var(--pt-font-body); font-size: 13px; font-weight: 700; padding: 10px 18px; border-radius: 999px; cursor: pointer; transition: all .2s; }
  .pt-promo-btn:hover { background: var(--pt-accent-soft); }
  /* Drawer footer */
  .pt-drawer-foot { padding: 22px 26px calc(22px + env(safe-area-inset-bottom, 0px)); border-top: 1px solid var(--pt-line); }
  .pt-deliver { display: flex; align-items: center; gap: 8px; font-size: 12.5px; color: var(--pt-ink-soft); margin-bottom: 14px; }
  .pt-drawer-sub { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 16px; }
  .pt-drawer-sub span { color: var(--pt-ink-soft); font-size: 14px; }
  .pt-drawer-sub b { font-family: var(--pt-font-head); font-size: 26px; }
  .pt-drawer-note { display: block; text-align: center; font-size: 12px; color: var(--pt-ink-faint); margin-top: 14px; }
  /* Toast */
  .pt-toast { position: fixed; left: 50%; bottom: 28px; z-index: 120; transform: translate(-50%, calc(100% + 40px)); display: flex; align-items: center; gap: 10px; background: #fff; color: var(--pt-ink); font-size: 14px; font-weight: 600; padding: 13px 16px 13px 18px; border-radius: 999px; border: 1px solid var(--pt-line); box-shadow: var(--pt-shadow-md); transition: transform .4s cubic-bezier(.3,.7,.4,1); font-family: var(--pt-font-body); white-space: nowrap; }
  .pt-toast.is-on { transform: translate(-50%, 0); }
  .pt-toast button { border: none; background: var(--pt-accent-soft); color: var(--pt-accent-deep); font-weight: 700; font-size: 12.5px; font-family: var(--pt-font-body); padding: 7px 13px; border-radius: 999px; cursor: pointer; margin-left: 4px; }
  .pt-toast button:hover { background: var(--pt-accent); color: #fff; }
  @media (max-width: 760px) {
    .pt-nav-left { display: none; }
    .pt-nav-hamburger { display: inline-flex; width: auto; }
    .pt-nav-inner { padding: 0 12px; grid-template-columns: auto 1fr auto; column-gap: 8px; }
    .pt-nav-inner > .pt-logo { justify-self: center; font-size: 21px; max-width: 100%; min-width: 0; }
    .pt-nav-inner > .pt-logo span { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; min-width: 0; }
    .pt-nav-right { gap: 4px; }
  }
  @media (max-width: 360px) {
    .pt-nav-inner > .pt-logo { font-size: 18px; }
  }
  .pt-search-overlay { position: fixed; inset: 0; z-index: 90; background: rgba(75,49,56,.4); backdrop-filter: blur(3px); opacity: 0; pointer-events: none; transition: opacity .25s; display: flex; align-items: flex-start; justify-content: center; padding: 90px 20px 20px; overflow-y: auto; }
  .pt-search-overlay[data-on="1"] { opacity: 1; pointer-events: auto; }
  .pt-search-panel { width: 100%; max-width: 640px; background: #fff; border-radius: var(--pt-radius); box-shadow: var(--pt-shadow-lg, 0 20px 60px rgba(0,0,0,.2)); overflow: hidden; transform: translateY(-12px); transition: transform .25s; }
  .pt-search-overlay[data-on="1"] .pt-search-panel { transform: translateY(0); }
  .pt-search-form { display: flex; align-items: center; gap: 10px; padding: 16px 18px; border-bottom: 1px solid var(--pt-line); color: var(--pt-ink-soft); }
  .pt-search-input { flex: 1; border: none; background: none; font-family: var(--pt-font-body); font-size: 15px; color: var(--pt-ink); }
  .pt-search-input:focus { outline: none; }
  .pt-search-submit { padding: 9px 18px; font-size: 13px; }
  .pt-search-live { max-height: 60vh; overflow-y: auto; }
  .pt-ps-results { padding: 14px 18px 18px; font-family: var(--pt-font-body); }
  .pt-ps-label { display: block; font-size: 11px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; color: var(--pt-ink-faint); margin: 14px 0 8px; }
  .pt-ps-queries { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 8px; }
  .pt-ps-queries a { display: inline-flex; align-items: center; gap: 7px; font-size: 13px; color: var(--pt-ink-soft); border: 1px solid var(--pt-line); border-radius: 999px; padding: 7px 14px; transition: all .15s; }
  .pt-ps-queries a:hover { border-color: var(--pt-accent); color: var(--pt-accent-deep); }
  .pt-ps-products { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; }
  .pt-ps-product { display: flex; align-items: center; gap: 12px; padding: 9px 6px; border-radius: 12px; transition: background .15s; }
  .pt-ps-product:hover { background: var(--pt-accent-soft); }
  .pt-ps-thumb { width: 46px; height: 46px; flex: none; border-radius: 10px; background: var(--pt-accent-soft); overflow: hidden; }
  .pt-ps-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .pt-ps-info b { display: block; font-size: 13.5px; color: var(--pt-ink); }
  .pt-ps-price { font-size: 12.5px; color: var(--pt-ink-soft); }
  .pt-ps-price s { color: var(--pt-ink-faint); margin-left: 6px; }
  .pt-ps-links { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 4px; }
  .pt-ps-links a { font-size: 13.5px; color: var(--pt-ink-soft); padding: 5px 6px; display: block; border-radius: 8px; }
  .pt-ps-links a:hover { background: var(--pt-accent-soft); color: var(--pt-accent-deep); }
  .pt-ps-none { font-size: 13.5px; color: var(--pt-ink-soft); margin: 8px 0; }
  .pt-ps-all { display: inline-flex; align-items: center; gap: 7px; margin-top: 14px; font-size: 13.5px; font-weight: 700; color: var(--pt-accent-deep); }
{% endstylesheet %}


<header class="pt-ch full-width">
  <nav class="pt-crumb" aria-label="{{ 'general.accessibility.nav_left' | t }}">
    <a href="{{ routes.root_url }}">{{ 'sections.collection.breadcrumb_home' | t }}</a>
    <span>/</span>
    <b>{{ 'sections.about.breadcrumb' | t }}</b>
  </nav>
  <span class="pt-eyebrow">
    <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
    {{ section.settings.eyebrow | escape }}
  </span>
  <h1 class="pt-ch-h">{{ section.settings.heading | escape }}</h1>
  {%- if section.settings.subheading != blank -%}
    <p class="pt-ch-blurb">{{ section.settings.subheading | escape }}</p>
  {%- endif -%}

  {%- if section.settings.show_stats -%}
    <div class="pt-hero-stats">
      <div class="pt-stat"><strong>{{ section.settings.stat_1_value | escape }}</strong><span>{{ section.settings.stat_1_label | escape }}</span></div>
      <div class="pt-stat"><strong>{{ section.settings.stat_2_value | escape }}</strong><span>{{ section.settings.stat_2_label | escape }}</span></div>
      <div class="pt-stat"><strong>{{ section.settings.stat_3_value | escape }}</strong><span>{{ section.settings.stat_3_label | escape }}</span></div>
    </div>
  {%- endif -%}
</header>

{% schema %}
{
  "name": "t:sections.about.hero_name",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Our story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Fantasy looks, real joy."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:labels.subheading",
      "default": "We make imitation fine jewelry for people who want the sparkle without the price tag — or the guilt. Every piece is designed to feel like a treasure and priced like a treat."
    },
    {
      "type": "checkbox",
      "id": "show_stats",
      "label": "t:labels.show_stats",
      "default": true
    },
    {
      "type": "text",
      "id": "stat_1_value",
      "label": "t:labels.stat_1_value",
      "default": "70%"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "t:labels.stat_1_label",
      "default": "less than the real thing"
    },
    {
      "type": "text",
      "id": "stat_2_value",
      "label": "t:labels.stat_2_value",
      "default": "4.9★"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "t:labels.stat_2_label",
      "default": "12k+ happy reviews"
    },
    {
      "type": "text",
      "id": "stat_3_value",
      "label": "t:labels.stat_3_value",
      "default": "∞"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "t:labels.stat_3_label",
      "default": "tarnish-free shine"
    }
  ],
  "presets": [
    {
      "name": "t:sections.about.hero_name"
    }
  ]
}
{% endschema %}

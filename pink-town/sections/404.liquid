{% comment %}
  This section is used in the 404 template to render page shown when customers
  enter an invalid store URL.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/404
{% endcomment %}

<section class="pt-404 full-width">
  <span class="pt-404-num">
    4
    <svg width="56" height="56" viewBox="0 0 24 24" fill="var(--pt-accent)" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
    4
  </span>
  <h1 class="pt-404-h">{{ section.settings.heading | escape }}</h1>
  <p class="pt-404-sub">{{ section.settings.subheading | escape }}</p>
  <div class="pt-404-ctas">
    <a href="{{ routes.root_url }}" class="pt-btn pt-btn--solid">{{ 'sections.404.back_home' | t }}</a>
    <a href="{{ routes.all_products_collection_url }}" class="pt-btn pt-btn--ghost">{{ 'sections.404.shop_collection' | t }}</a>
  </div>
  {%- if section.settings.quick_links.links.size > 0 -%}
    <div class="pt-404-links">
      {%- for link in section.settings.quick_links.links -%}
        <a href="{{ link.url }}">{{ link.title | escape }}</a>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .pt-404 { width: 100%; max-width: 640px; margin: 0 auto; padding: 110px 32px 120px; text-align: center; display: flex; flex-direction: column; align-items: center; font-family: var(--pt-font-body); }
  .pt-404-num { font-family: var(--pt-font-head); font-size: clamp(4rem, 12vw, 7rem); font-weight: 500; line-height: 1; color: var(--pt-ink); display: inline-flex; align-items: center; gap: 8px; }
  .pt-404-h { font-family: var(--pt-font-head); font-size: clamp(1.8rem, 3.4vw, 2.4rem); margin-top: 22px; }
  .pt-404-sub { color: var(--pt-ink-soft); font-size: 15.5px; line-height: 1.6; max-width: 42ch; margin: 16px 0 0; }
  .pt-404-ctas { display: flex; gap: 14px; margin-top: 34px; flex-wrap: wrap; justify-content: center; }
  .pt-404-links { display: flex; gap: 22px; flex-wrap: wrap; justify-content: center; margin-top: 40px; padding-top: 32px; border-top: 1px solid var(--pt-line); }
  .pt-404-links a { font-size: 13.5px; font-weight: 600; color: var(--pt-ink-soft); }
  .pt-404-links a:hover { color: var(--pt-accent-deep); text-decoration: underline; }
  @media (max-width: 560px) {
    .pt-404 { padding: 70px 20px 80px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.404",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "This page has slipped away"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:labels.subheading",
      "default": "The page you're looking for doesn't exist, moved, or maybe never did. Let's get you back to something shiny."
    },
    {
      "type": "link_list",
      "id": "quick_links",
      "label": "t:labels.quick_links",
      "default": "main-menu"
    }
  ]
}
{% endschema %}

<section class="pt-section pt-section--tint full-width" id="store-locations-{{ section.id }}">
  <div class="pt-sec-head pt-sec-head--center">
    <span class="pt-eyebrow">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
      {{ section.settings.eyebrow | escape }}
    </span>
    <h2 class="pt-h2">{{ section.settings.heading | escape }}</h2>
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="pt-locs-wrap">
      <div class="pt-locs-list">
        {%- for block in section.blocks -%}
          <button type="button" class="pt-loc-card" data-loc-card data-loc-id="{{ block.id }}" data-on="{% if forloop.first %}1{% else %}0{% endif %}" {{ block.shopify_attributes }}>
            <div class="pt-loc-name"><span class="pt-loc-pin">{{ block.settings.code | escape }}</span>{{ block.settings.name | escape }}</div>
            <p class="pt-loc-addr">{{ block.settings.address | escape }}</p>
            <p class="pt-loc-hours">{{ block.settings.hours | escape }}{% if block.settings.phone != blank %} &middot; {{ block.settings.phone | escape }}{% endif %}</p>
          </button>
        {%- endfor -%}
      </div>

      <div class="pt-map">
        <span class="pt-map-lbl">{{ 'sections.store_locations.map_label' | t }}</span>
        {%- for block in section.blocks -%}
          <button type="button" class="pt-map-pin" data-map-pin data-loc-id="{{ block.id }}" data-on="{% if forloop.first %}1{% else %}0{% endif %}"
                  style="left:{{ block.settings.pin_x }}%;top:{{ block.settings.pin_y }}%"
                  aria-label="{{ block.settings.name | escape }}" title="{{ block.settings.name | escape }}">
            <span>{{ block.settings.code | escape }}</span>
          </button>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .pt-locs-wrap { display: grid; grid-template-columns: .8fr 1.2fr; gap: 28px; align-items: start; width: 100%; font-family: var(--pt-font-body); }
  .pt-locs-list { display: flex; flex-direction: column; gap: 14px; }
  .pt-loc-card { text-align: left; background: #fff; border: 1px solid var(--pt-line); border-radius: var(--pt-radius); padding: 20px 22px; cursor: pointer; transition: border-color .2s, box-shadow .2s; }
  .pt-loc-card:hover { border-color: var(--pt-accent); }
  .pt-loc-card[data-on="1"] { border-color: var(--pt-accent-deep); box-shadow: var(--pt-shadow-sm); }
  .pt-loc-name { display: flex; align-items: center; gap: 10px; font-family: var(--pt-font-head); font-size: 19px; color: var(--pt-ink); }
  .pt-loc-pin { flex: none; width: 30px; height: 30px; border-radius: 50%; background: var(--pt-accent-soft); color: var(--pt-accent-deep); display: grid; place-items: center; font-family: var(--pt-font-body); font-size: 11px; font-weight: 800; }
  .pt-loc-addr { font-size: 13.5px; color: var(--pt-ink-soft); margin: 8px 0 4px; }
  .pt-loc-hours { font-size: 12.5px; color: var(--pt-ink-faint); margin: 0; }
  .pt-map { position: relative; min-height: 380px; border-radius: var(--pt-radius); overflow: hidden; background: linear-gradient(160deg, var(--pt-accent-soft), var(--pt-bg-tint)); box-shadow: var(--pt-shadow-sm); }
  .pt-map-lbl { position: absolute; top: 16px; left: 16px; font-size: 10.5px; letter-spacing: .14em; text-transform: uppercase; color: rgba(60,50,55,.5); background: rgba(255,255,255,.72); padding: 4px 10px; border-radius: 999px; }
  .pt-map-pin { position: absolute; transform: translate(-50%, -50%) rotate(-45deg); width: 36px; height: 36px; border-radius: 50% 50% 50% 0; border: none; background: var(--pt-accent); color: #fff; display: grid; place-items: center; cursor: pointer; box-shadow: var(--pt-shadow-sm); transition: background .2s, transform .2s; }
  .pt-map-pin span { display: block; transform: rotate(45deg); font-size: 10px; font-weight: 800; }
  .pt-map-pin[data-on="1"] { background: var(--pt-accent-deep); transform: translate(-50%, -50%) rotate(-45deg) scale(1.15); }
  @media (max-width: 760px) {
    .pt-locs-wrap { grid-template-columns: 1fr; }
    .pt-map { min-height: 260px; }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    document.querySelectorAll('[id^="store-locations-"]').forEach(function (section) {
      var cards = section.querySelectorAll('[data-loc-card]');
      var pins = section.querySelectorAll('[data-map-pin]');
      function activate(id) {
        cards.forEach(function (c) { c.dataset.on = c.dataset.locId === id ? '1' : '0'; });
        pins.forEach(function (p) { p.dataset.on = p.dataset.locId === id ? '1' : '0'; });
      }
      cards.forEach(function (c) { c.addEventListener('click', function () { activate(c.dataset.locId); }); });
      pins.forEach(function (p) { p.addEventListener('click', function () { activate(p.dataset.locId); }); });
    });
  })();
{% endjavascript %}


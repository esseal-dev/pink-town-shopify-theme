{%- comment -%}
  Blocks are a flat list of Q&A pairs, each tagged with a group label. This
  loop breaks the flat list into visual groups by detecting when the group
  label changes between consecutive blocks — merchants control grouping just
  by keeping same-group questions next to each other in the block list.
{%- endcomment -%}

<div class="pt-faq-wrap full-width" data-faq-wrap
     data-i-no-match="{{ 'sections.faq.no_match_html' | t | escape }}"
     data-i-contact-text="{{ 'sections.faq.contact_link_text' | t | escape }}"
     data-i-contact-url="{{ routes.root_url | append: 'pages/contact' | escape }}">
  {%- assign last_group = '' -%}
  {%- for block in section.blocks -%}
    {%- if block.settings.group != last_group -%}
      {%- unless forloop.first -%}</div>{%- endunless -%}
      <div class="pt-faq-group" data-faq-group data-group-name="{{ block.settings.group | escape }}">
        <h2 class="pt-faq-group-title">{{ block.settings.group | escape }}</h2>
      {%- assign last_group = block.settings.group -%}
    {%- endif -%}
    <div class="pt-faq-item" data-faq-item data-open="{% if forloop.first %}1{% else %}0{% endif %}" {{ block.shopify_attributes }}
         data-q="{{ block.settings.question | escape | downcase }}" data-a="{{ block.settings.answer | escape | downcase }}">
      <button type="button" class="pt-faq-q" data-faq-toggle aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}">
        {{ block.settings.question | escape }}
        <span class="pt-faq-q-ic">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg>
        </span>
      </button>
      <div class="pt-faq-a-wrap">
        <div class="pt-faq-a-inner">
          <p class="pt-faq-a">{{ block.settings.answer | escape }}</p>
        </div>
      </div>
    </div>
    {%- if forloop.last -%}</div>{%- endif -%}
  {%- endfor -%}

  <div class="pt-faq-empty" data-faq-empty hidden></div>
</div>

{% stylesheet %}
  .pt-faq-wrap { width: 100%; max-width: 820px; margin: 0 auto; padding: 12px 32px 100px; font-family: var(--pt-font-body); }
  .pt-faq-group { margin-bottom: 40px; }
  .pt-faq-group-title { font-family: var(--pt-font-head); font-size: 22px; margin-bottom: 16px; }
  .pt-faq-item { border-bottom: 1px solid var(--pt-line); }
  .pt-faq-q { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 16px; text-align: left; border: none; background: none; padding: 18px 2px; font-family: var(--pt-font-body); font-size: 15px; font-weight: 600; color: var(--pt-ink); cursor: pointer; }
  .pt-faq-q-ic { flex: none; width: 26px; height: 26px; border-radius: 50%; background: var(--pt-accent-soft); color: var(--pt-accent-deep); display: grid; place-items: center; transition: transform .25s; }
  .pt-faq-item[data-open="1"] .pt-faq-q-ic { transform: rotate(45deg); }
  .pt-faq-a-wrap { display: grid; grid-template-rows: 0fr; transition: grid-template-rows .3s ease; }
  .pt-faq-item[data-open="1"] .pt-faq-a-wrap { grid-template-rows: 1fr; }
  .pt-faq-a-inner { overflow: hidden; }
  .pt-faq-a { font-size: 14px; line-height: 1.65; color: var(--pt-ink-soft); margin: 0 2px 20px; max-width: 62ch; }
  .pt-faq-empty { text-align: center; padding: 60px 20px; color: var(--pt-ink-soft); font-size: 14.5px; }
  .pt-faq-empty a { color: var(--pt-accent-deep); font-weight: 700; }
  .pt-faq-empty a:hover { text-decoration: underline; }
  @media (max-width: 560px) {
    .pt-faq-wrap { padding: 8px 20px 70px; }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    document.querySelectorAll('[data-faq-wrap]').forEach(function (wrap) {
      var groups = wrap.querySelectorAll('[data-faq-group]');
      var items = wrap.querySelectorAll('[data-faq-item]');
      var emptyEl = wrap.querySelector('[data-faq-empty]');

      wrap.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-faq-toggle]');
        if (!btn) return;
        var item = btn.closest('[data-faq-item]');
        var willOpen = item.dataset.open !== '1';
        item.dataset.open = willOpen ? '1' : '0';
        btn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
      });

      function applyFilter(query) {
        var q = (query || '').trim().toLowerCase();
        var anyVisible = false;
        groups.forEach(function (group) {
          var groupHasMatch = false;
          group.querySelectorAll('[data-faq-item]').forEach(function (item) {
            var match = !q || item.dataset.q.indexOf(q) !== -1 || item.dataset.a.indexOf(q) !== -1;
            item.hidden = !match;
            if (match) { groupHasMatch = true; anyVisible = true; }
          });
          group.hidden = !groupHasMatch;
        });
        if (emptyEl) {
          emptyEl.hidden = anyVisible;
          if (!anyVisible) {
            var html = wrap.dataset.iNoMatch.replace('{query}', '&ldquo;' + q.replace(/&/g, '&amp;').replace(/</g, '&lt;') + '&rdquo;');
            emptyEl.innerHTML = html + ' <a href="' + wrap.dataset.iContactUrl + '">' + wrap.dataset.iContactText + '</a>';
          }
        }
      }

      window.addEventListener('pt:faq-search', function (e) { applyFilter(e.detail); });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.faq.accordion_name",
  "blocks": [
    {
      "type": "question",
      "name": "t:sections.faq.blocks.question.name",
      "settings": [
        {
          "type": "text",
          "id": "group",
          "label": "t:labels.faq_group",
          "info": "t:labels.faq_group_info",
          "default": "General"
        },
        {
          "type": "text",
          "id": "question",
          "label": "t:labels.faq_question",
          "default": "Question goes here?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "t:labels.faq_answer",
          "default": "Answer goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.faq.accordion_name",
      "blocks": [
        {
          "type": "question",
          "settings": {
            "group": "Orders & Shipping",
            "question": "How long does shipping take?",
            "answer": "Most orders ship within 1–2 business days and arrive in 3–6 business days within the US. You'll get a tracking link by email the moment your order ships."
          }
        },
        {
          "type": "question",
          "settings": {

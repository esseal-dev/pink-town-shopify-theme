{% comment %}
  Pickup availability for the selected variant. Never placed in a template —
  the product page fetches this section via the Section Rendering API
  ({{ product.url }}?variant=…&section_id=pickup-availability) on load and
  whenever the shopper switches variants.
{% endcomment %}

{%- assign pa_variant = product.selected_or_first_available_variant -%}
{%- if pa_variant.store_availabilities.size > 0 -%}
  <div class="pt-pickup">
    {%- for availability in pa_variant.store_availabilities limit: 3 -%}
      <div class="pt-pickup-loc">
        {%- if availability.available -%}
          <svg class="pt-pickup-ic pt-pickup-ic--ok" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        {%- else -%}
          <svg class="pt-pickup-ic pt-pickup-ic--no" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/></svg>
        {%- endif -%}
        <div class="pt-pickup-txt">
          {%- if availability.available -%}
            <b>{{ 'products.pickup_available_at' | t: location: availability.location.name }}</b>
            {%- if availability.pick_up_time != blank -%}
              <span>{{ 'products.pickup_ready_in' | t: time: availability.pick_up_time }}</span>
            {%- endif -%}
          {%- else -%}
            <b>{{ 'products.pickup_unavailable_at' | t: location: availability.location.name }}</b>
          {%- endif -%}
          {%- if availability.location.address -%}
            <span>{{ availability.location.address | format_address | strip_html | truncate: 60 }}</span>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.pickup_availability.name",
  "settings": []
}
{% endschema %}

<header class="pt-ch full-width">
  <nav class="pt-crumb" aria-label="{{ 'general.accessibility.nav_left' | t }}">
    <a href="{{ routes.root_url }}">{{ 'sections.collection.breadcrumb_home' | t }}</a>
    <span>/</span>
    <b>{{ 'sections.faq.breadcrumb' | t }}</b>
  </nav>
  <span class="pt-eyebrow">
    <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
    {{ section.settings.eyebrow | escape }}
  </span>
  <h1 class="pt-ch-h">{{ section.settings.heading | escape }}</h1>
  {%- if section.settings.subheading != blank -%}
    <p class="pt-ch-blurb">{{ section.settings.subheading | escape }}</p>
  {%- endif -%}

  <label class="pt-faq-search">
    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3" stroke-linecap="round"/></svg>
    <input type="text" data-faq-search placeholder="{{ 'sections.faq.search_placeholder' | t }}" aria-label="{{ 'sections.faq.search_label' | t }}">
  </label>
</header>

{% stylesheet %}
  .pt-faq-search { display: flex; align-items: center; gap: 10px; max-width: 440px; margin: 26px auto 0; padding: 13px 18px; background: #fff; border: 1px solid var(--pt-line); border-radius: 999px; color: var(--pt-ink-faint); box-shadow: var(--pt-shadow-sm); }
  .pt-faq-search input { flex: 1; min-width: 0; border: none; outline: none; background: none; font-family: var(--pt-font-body); font-size: 14px; color: var(--pt-ink); }
  .pt-faq-search input::placeholder { color: var(--pt-ink-faint); }
{% endstylesheet %}

{% javascript %}
  (function () {
    document.querySelectorAll('[data-faq-search]').forEach(function (input) {
      input.addEventListener('input', function () {
        window.dispatchEvent(new CustomEvent('pt:faq-search', { detail: input.value }));
      });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.faq.hero_name",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Here to help"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:labels.subheading",
      "default": "Everything you need to know about orders, shipping, returns, and caring for your pieces. Can't find an answer? Our team is one message away."
    }
  ],
  "presets": [
    {
      "name": "t:sections.faq.hero_name"
    }
  ]
}
{% endschema %}

        { "value": "split", "label": "t:options.collection_layout.split" },
        { "value": "centered", "label": "t:options.collection_layout.centered" },
        { "value": "fullbleed", "label": "t:options.collection_layout.fullbleed" }
      ],
      "default": "split"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Shop the edit"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "t:labels.badge_text",
      "default": "New pieces weekly"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "t:labels.show_rating",
      "default": true
    },
    {
      "type": "text",
      "id": "rating",
      "label": "t:labels.rating",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "t:labels.review_count",
      "default": "218"
    },
    {
      "type": "select",
      "id": "grid_columns",
      "label": "t:labels.grid_columns",
      "options": [
        { "value": "3", "label": "t:options.grid_columns.three" },
        { "value": "4", "label": "t:options.grid_columns.four" }
      ],
      "default": "3"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "t:labels.products_per_page",
      "min": 12,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "enable_variant_filters",
      "label": "t:labels.enable_variant_filters",
      "info": "t:labels.enable_variant_filters_info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_price_filter",
      "label": "t:labels.enable_price_filter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_promo",
      "label": "t:labels.show_promo",
      "default": true
    },
    {
      "type": "text",
      "id": "promo_eyebrow",
      "label": "t:labels.promo_eyebrow",
      "default": "Limited time"
    },
    {
      "type": "text",
      "id": "promo_heading",
      "label": "t:labels.promo_heading",
      "default": "Buy 2, get 1 free"
    },
    {
      "type": "textarea",
      "id": "promo_text",
      "label": "t:labels.promo_text",
      "default": "Mix & match any pieces — your lowest-priced item is on us. Auto-applied at checkout."
    },
    {
      "type": "text",
      "id": "promo_badge",
      "label": "t:labels.promo_badge",
      "default": "No code needed ♡"
    }
  ]
}

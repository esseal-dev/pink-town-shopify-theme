  .pt-pdp-perks li { display: flex; align-items: center; gap: 9px; font-size: 12.5px; color: var(--pt-ink-soft); }
  .pt-pdp-perk-ic { width: 26px; height: 26px; flex: none; display: grid; place-items: center; border-radius: 50%; background: var(--pt-accent-soft); color: var(--pt-accent-deep); font-size: 13px; }

  .pt-pdp-share { display: flex; align-items: center; gap: 10px; margin-top: 24px; }
  .pt-pdp-share-lbl { font-size: 12px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--pt-ink-faint); margin-right: 2px; }
  .pt-pdp-share-btn { width: 34px; height: 34px; border-radius: 50%; border: 1px solid var(--pt-line); background: #fff; color: var(--pt-ink-soft); display: grid; place-items: center; cursor: pointer; transition: all .2s; font-family: var(--pt-font-head); font-size: 15px; text-decoration: none; }
  .pt-pdp-share-btn:hover { border-color: var(--pt-accent); color: var(--pt-accent-deep); transform: translateY(-1px); }
  .pt-pdp-share-copied { font-size: 12.5px; color: var(--pt-accent-deep); font-weight: 600; }

  .pt-pdp-acc { border-top: 1px solid var(--pt-line); }
  .pt-pdp-acc-item { border-bottom: 1px solid var(--pt-line); }
  .pt-pdp-acc-q { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 16px; text-align: left; border: none; background: none; font-family: var(--pt-font-head); font-size: 20px; color: var(--pt-ink); padding: 18px 0; cursor: pointer; }
  .pt-pdp-acc-q svg { color: var(--pt-accent-deep); transition: transform .25s; flex: none; }
  .pt-pdp-acc-item[data-open="1"] .pt-pdp-acc-q svg { transform: rotate(45deg); }
  .pt-pdp-acc-a-wrap { display: grid; grid-template-rows: 0fr; transition: grid-template-rows .3s ease; }
  .pt-pdp-acc-item[data-open="1"] .pt-pdp-acc-a-wrap { grid-template-rows: 1fr; }
  .pt-pdp-acc-a-inner { overflow: hidden; }
  .pt-pdp-acc-a { font-size: 14px; line-height: 1.65; color: var(--pt-ink-soft); margin: 0 0 20px; max-width: 60ch; }

  .pt-pdp-sec { max-width: var(--pt-wrap); margin: 0 auto; padding: 70px 32px; font-family: var(--pt-font-body); }
  .pt-pdp-sec--tint { max-width: none; margin: 0; background: radial-gradient(120% 80% at 50% 0%, var(--pt-accent-soft) 0%, transparent 55%), var(--pt-bg-tint); }
  .pt-pdp-sec--tint > * { max-width: var(--pt-wrap); margin-left: auto; margin-right: auto; }
  .pt-pdp-h { font-family: var(--pt-font-head); font-size: clamp(2rem, 3.4vw, 2.8rem); line-height: 1.05; letter-spacing: -.01em; }
  .pt-pdp-h--center { text-align: center; }
  .pt-pdp-desc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: start; }
  .pt-pdp-p { font-size: 16px; line-height: 1.7; color: var(--pt-ink-soft); margin: 18px 0 0; max-width: 46ch; }
  .pt-pdp-p p:not(:last-child) { margin-bottom: 10px; }
  .pt-pdp-highlights { margin-top: 22px; display: flex; flex-direction: column; gap: 12px; }
  .pt-pdp-highlights li { display: flex; align-items: flex-start; gap: 10px; font-size: 14.5px; color: var(--pt-ink); }
  .pt-pdp-highlights svg { margin-top: 3px; flex: none; }

  .pt-pdp-related .pt-sec-head { margin-bottom: 32px; }
  .pt-prod-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 26px 22px; margin-top: 8px; }
  .pt-card { position: relative; }
  .pt-card-media { position: relative; border-radius: var(--pt-radius); overflow: hidden; aspect-ratio: 1/1; box-shadow: var(--pt-shadow-sm); }
  .pt-card-tag { position: absolute; top: 12px; left: 12px; z-index: 3; background: rgba(255,255,255,.94); color: var(--pt-accent-deep); font-size: 10.5px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; padding: 5px 10px; border-radius: 999px; font-family: var(--pt-font-body); }
  .pt-wish { position: absolute; top: 10px; right: 10px; z-index: 3; width: 34px; height: 34px; border: none; display: grid; place-items: center; background: rgba(255,255,255,.9); color: var(--pt-ink-soft); border-radius: 50%; cursor: pointer; transition: color .2s, transform .2s, background .2s; }
  .pt-wish:hover { transform: scale(1.1); }
  .pt-wish[data-on="1"] { color: var(--pt-accent); background: #fff; }
  .pt-add { position: absolute; left: 12px; right: 12px; bottom: 12px; z-index: 3; border: none; background: rgba(255,255,255,.96); color: var(--pt-ink); font-family: var(--pt-font-body); font-weight: 700; font-size: 13px; padding: 12px; border-radius: 999px; cursor: pointer; box-shadow: var(--pt-shadow-sm); opacity: 0; transform: translateY(12px); transition: opacity .3s, transform .3s, background .25s, color .25s; text-align: center; }
  .pt-card-media:hover .pt-add { opacity: 1; transform: translateY(0); }
  .pt-add:hover { background: linear-gradient(135deg, var(--pt-accent), var(--pt-accent-deep)); color: #fff; }
  .pt-add.is-added { opacity: 1; transform: translateY(0); background: var(--pt-accent-deep); color: #fff; }
  .pt-add--soldout { opacity: 1; transform: none; background: rgba(255,255,255,.8); color: var(--pt-ink-faint); cursor: default; }
  @media (hover: none) { .pt-add { opacity: 1; transform: none; } }
  .pt-card-info { padding: 15px 2px 0; }
  .pt-card-cat { font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--pt-ink-faint); font-family: var(--pt-font-body); }
  .pt-card-name { font-family: var(--pt-font-head); font-size: 20px; margin: 3px 0 8px; line-height: 1.1; }
  .pt-card-name a { color: inherit; }
  .pt-card-name a:hover { color: var(--pt-accent-deep); }
  .pt-card-price { display: flex; align-items: center; gap: 9px; flex-wrap: wrap; }
  .pt-price-now { font-weight: 800; font-size: 15px; color: var(--pt-ink); font-family: var(--pt-font-body); }
  .pt-price-was { font-size: 13px; color: var(--pt-ink-faint); text-decoration: line-through; font-family: var(--pt-font-body); }
  .pt-price-save { margin-left: auto; font-size: 11px; font-weight: 800; color: var(--pt-accent-deep); background: var(--pt-accent-soft); padding: 3px 8px; border-radius: 999px; white-space: nowrap; font-family: var(--pt-font-body); }

  .pt-pdp-sticky { position: fixed; left: 0; right: 0; bottom: 0; z-index: 90; background: rgba(255,250,251,.95); backdrop-filter: blur(14px) saturate(150%); border-top: 1px solid var(--pt-line); box-shadow: 0 -10px 30px -18px rgba(120,60,75,.4); transform: translateY(110%); transition: transform .35s cubic-bezier(.3,.7,.4,1); }
  .pt-pdp-sticky.is-on { transform: translateY(0); }
  .pt-pdp-sticky-in { max-width: var(--pt-wrap); margin: 0 auto; padding: 12px 32px; display: flex; align-items: center; gap: 18px; }
  .pt-pdp-sticky-prod { display: flex; align-items: center; gap: 12px; border: none; background: none; cursor: pointer; text-align: left; padding: 0; font-family: var(--pt-font-body); min-width: 0; }
  .pt-pdp-sticky-img { position: relative; width: 46px; height: 46px; flex: none; border-radius: 10px; overflow: hidden; background: var(--pt-accent-soft); }
  .pt-pdp-sticky-meta { display: flex; flex-direction: column; min-width: 0; }
  .pt-pdp-sticky-meta b { font-family: var(--pt-font-head); font-size: 18px; line-height: 1.1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .pt-pdp-sticky-meta i { font-size: 12px; color: var(--pt-ink-soft); font-style: normal; }
  .pt-pdp-sticky-price { margin-left: auto; display: flex; align-items: baseline; gap: 8px; }
  .pt-pdp-sticky-price .pt-price-now { font-size: 18px; }
  .pt-pdp-sticky-add { white-space: nowrap; flex: none; }

  @media (max-width: 920px) {
    .pt-pdp-wrap { grid-template-columns: 1fr; gap: 32px; }
    .pt-pdp--right .pt-pdp-media, .pt-pdp--right .pt-pdp-info { order: initial; }
    .pt-pdp-info { position: static; }
    .pt-pdp-desc-grid { grid-template-columns: 1fr; gap: 32px; }
    .pt-prod-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .pt-pdp-top { padding: 18px 20px 8px; }
    .pt-pdp-sec { padding: 50px 20px; }
    .pt-pdp-actions { flex-wrap: wrap; }
    .pt-pdp-add { flex: 1 1 100%; order: -1; }
    .pt-pdp-perks { grid-template-columns: 1fr; }
    .pt-prod-grid { grid-template-columns: repeat(2, 1fr); gap: 18px 12px; }
    .pt-pdp-sticky-in { padding: 10px 16px; gap: 12px; }
    .pt-pdp-sticky-meta { display: none; }
    .pt-pdp-sticky-add { flex: 1; }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    document.querySelectorAll('[data-pdp]').forEach(function (pdp) {
      var variantsScript = pdp.querySelector('[data-pdp-variants]');
      if (!variantsScript) return;
      var variants = JSON.parse(variantsScript.textContent);
      var variantSelect = pdp.querySelector('[data-pdp-variant-select]');
      var fields = Array.prototype.slice.call(pdp.querySelectorAll('[data-pdp-field]'));
      var mainMedia = pdp.querySelector('[data-pdp-main]');
      var thumbs = Array.prototype.slice.call(pdp.querySelectorAll('[data-pdp-thumb]'));
      var priceEl = pdp.querySelector('[data-pdp-price]');
      var addBtn = pdp.querySelector('[data-pdp-add]');
      var buyNowBtn = pdp.querySelector('[data-pdp-buynow]');
      var dynamicWrap = pdp.querySelector('[data-pdp-dynamic]');
      var qtyEl = pdp.querySelector('[data-pdp-qty]');
      var qtyDec = pdp.querySelector('[data-pdp-qty-dec]');
      var qtyInc = pdp.querySelector('[data-pdp-qty-inc]');
      var stockWrap = pdp.querySelector('[data-pdp-stock]');
      var stockBar = pdp.querySelector('[data-pdp-stock-bar]');
      var stockMsg = pdp.querySelector('[data-pdp-stock-msg]');
      var showStock = pdp.dataset.showStock === 'true';
      var stockThreshold = parseInt(pdp.dataset.stockThreshold, 10) || 0;

      var sticky = document.querySelector('[data-pdp-sticky]');
      var stickyImg = sticky ? sticky.querySelector('[data-pdp-sticky-img]') : null;
      var stickyVariant = sticky ? sticky.querySelector('[data-pdp-sticky-variant]') : null;
      var stickyPrice = sticky ? sticky.querySelector('[data-pdp-sticky-price]') : null;
      var stickyAdd = sticky ? sticky.querySelector('[data-pdp-sticky-add]') : null;

      var i18n = {
        addToCart: pdp.dataset.iAddToCart,
        soldOut: pdp.dataset.iSoldOut,
        finishHtml: pdp.dataset.iFinishHtml,
        sizeSelectedHtml: pdp.dataset.iSizeSelectedHtml,
        sizeLabel: pdp.dataset.iSizeLabel,
        lengthLabel: pdp.dataset.iLengthLabel,
        stockLowHtml: pdp.dataset.iStockLowHtml,
        copied: pdp.dataset.iCopied
      };

      var selected = variantSelect
        ? (variants.filter(function (v) { return String(v.id) === variantSelect.value; })[0] || variants[0] || { options: [] }).options.slice()
        : [];
      var qtyVal = 1;

      function money(cents) {
        return '$' + (cents / 100).toFixed(2).replace(/\.00$/, '');
      }

      function findVariant() {
        return variants.filter(function (v) {
          return v.options.every(function (val, i) { return val === selected[i]; });
        })[0] || null;
      }

      function fieldLabelHtml(field) {
        var isSwatch = field.querySelector('.pt-pdp-colors') !== null;
        var i = parseInt(field.dataset.optIndex, 10);
        var value = selected[i];
        if (isSwatch) return i18n.finishHtml.replace('%%VALUE%%', value);
        var optLabel = field.dataset.optLabel;
        return i18n.sizeSelectedHtml.replace('%%LABEL%%', optLabel).replace('%%VALUE%%', value);
      }

      function updateAddButtons(variant) {
        var available = !!(variant && variant.available);
        [addBtn, stickyAdd].forEach(function (btn) {
          if (!btn) return;
          btn.disabled = !available;
          btn.textContent = available ? i18n.addToCart + ' · ' + money(variant.price * qtyVal) : i18n.soldOut;
        });
        if (buyNowBtn) buyNowBtn.disabled = !available;
      }

      function updateStock(variant) {
        if (!stockWrap || !showStock) return;
        var qty = variant ? variant.inventory_quantity : null;
        var tracked = variant && variant.inventory_management === 'shopify' && variant.inventory_policy !== 'continue';
        var show = tracked && qty > 0 && qty <= stockThreshold;
        stockWrap.hidden = !show;
        if (show) {
          if (stockMsg) stockMsg.innerHTML = i18n.stockLowHtml.replace('%%COUNT%%', qty);
          if (stockBar) stockBar.style.width = Math.max(8, (qty / stockThreshold) * 100) + '%';
        }
      }

      function render() {
        var variant = findVariant();

        fields.forEach(function (field) {
          var label = field.querySelector('[data-pdp-flabel]');
          if (label) label.innerHTML = fieldLabelHtml(field);
        });

        if (!variant) {
          updateAddButtons(null);
          if (dynamicWrap) dynamicWrap.hidden = true;
          if (stockWrap) stockWrap.hidden = true;
          return;
        }

        if (priceEl) {
          priceEl.innerHTML = '<span class="pt-price-now">' + money(variant.price) + '</span>' +
            (variant.compare_at_price > variant.price ? '<span class="pt-price-was">' + money(variant.compare_at_price) + '</span>' : '');
        }
        updateAddButtons(variant);
        updateStock(variant);
        if (dynamicWrap) dynamicWrap.hidden = !variant.available;
        if (variantSelect && String(variantSelect.value) !== String(variant.id)) {
          variantSelect.value = variant.id;
          variantSelect.dispatchEvent(new Event('change', { bubbles: true }));
        }
        if (variant.featured_image) {
          setMainImage(variant.featured_image.src, variant.featured_image.id);
        }
        if (stickyImg && variant.featured_image) {
          stickyImg.innerHTML = '<img class="pt-ph-img" src="' + variant.featured_image.src.replace(/(\.\w+)(\?|$)/, '_100x100$1$2') + '" alt="">';
        }
        if (stickyVariant) stickyVariant.textContent = variant.title !== 'Default Title' ? variant.title : '';
        if (stickyPrice) {
          stickyPrice.innerHTML = '<span class="pt-price-now">' + money(variant.price) + '</span>' +
            (variant.compare_at_price > variant.price ? '<span class="pt-price-was">' + money(variant.compare_at_price) + '</span>' : '');
        }

        if (window.history && window.history.replaceState) {
          var url = new URL(window.location.href);
          url.searchParams.set('variant', variant.id);
          window.history.replaceState({}, '', url);
        }
      }

      function setMainImage(src, imageId) {
        if (mainMedia) {
          mainMedia.innerHTML = '<img class="pt-ph-img" src="' + src.replace(/(\.\w+)(\?|$)/, '_1200x1200$1$2') + '" alt="">';
        }
        thumbs.forEach(function (t) {
          t.dataset.on = imageId && String(t.dataset.imageId) === String(imageId) ? '1' : '0';
        });
      }

      fields.forEach(function (field) {
        var label = field.querySelector('[data-pdp-flabel]');
        var isSwatch = field.querySelector('.pt-pdp-colors') !== null;
        if (!isSwatch && label) {
          var i = parseInt(field.dataset.optIndex, 10);
          field.dataset.optLabel = /size/i.test(field.dataset.optName || '') ? i18n.sizeLabel
            : /length/i.test(field.dataset.optName || '') ? i18n.lengthLabel
            : label.textContent.split(' — ')[0];
        }
      });

      pdp.querySelectorAll('[data-pdp-option]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var i = parseInt(btn.dataset.optIndex, 10);
          selected[i] = btn.dataset.optValue;
          var wrap = btn.parentElement;
          wrap.querySelectorAll('[data-pdp-option]').forEach(function (b) { b.dataset.on = '0'; });
          btn.dataset.on = '1';
          render();
        });
      });

      thumbs.forEach(function (thumb) {
        thumb.addEventListener('click', function () {
          thumbs.forEach(function (t) { t.dataset.on = '0'; });
          thumb.dataset.on = '1';
          if (mainMedia) mainMedia.innerHTML = '<img class="pt-ph-img" src="' + thumb.dataset.src + '" alt="">';
        });
      });

      if (qtyDec) qtyDec.addEventListener('click', function () {
        qtyVal = Math.max(1, qtyVal - 1);
        qtyEl.textContent = qtyVal;
        updateAddButtons(findVariant());
      });
      if (qtyInc) qtyInc.addEventListener('click', function () {
        qtyVal += 1;
        qtyEl.textContent = qtyVal;
        updateAddButtons(findVariant());
      });

      function addToCart(triggerBtn, redirectToCheckout) {
        var variant = findVariant();
        if (!variant || !variant.available) return;
        [addBtn, stickyAdd, buyNowBtn].forEach(function (b) { if (b) b.disabled = true; });
        var original = triggerBtn.textContent;
        triggerBtn.textContent = '…';

        var items = [{ id: variant.id, quantity: qtyVal }];
        pdp.querySelectorAll('[data-pdp-addon-check]:checked').forEach(function (cb) {
          var wrap = cb.closest('[data-pdp-addon]');
          items.push({ id: parseInt(wrap.dataset.variantId, 10), quantity: 1 });
        });

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: items })
        }).then(function () {
          if (redirectToCheckout) {
            window.location.href = pdp.dataset.checkoutUrl;
            return;
          }
          if (window.ptOpenCart) window.ptOpenCart();
          updateAddButtons(variant);
        }).catch(function () {
          updateAddButtons(variant);
          triggerBtn.textContent = original;
        });
      }

      if (addBtn) addBtn.addEventListener('click', function () { addToCart(addBtn); });
      if (stickyAdd) stickyAdd.addEventListener('click', function () { addToCart(stickyAdd); });
      if (buyNowBtn) buyNowBtn.addEventListener('click', function () { addToCart(buyNowBtn, true); });

      var acc = pdp.querySelector('[data-pdp-acc]') || document.querySelector('[data-pdp-acc]');
      if (acc) {
        acc.addEventListener('click', function (e) {
          var btn = e.target.closest('[data-pdp-acc-toggle]');
          if (!btn) return;
          var item = btn.closest('[data-pdp-acc-item]');
          var willOpen = item.dataset.open !== '1';
          item.dataset.open = willOpen ? '1' : '0';
          btn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        });
      }

      var reviewsJump = pdp.querySelector('[data-pdp-reviews-jump]');
      if (reviewsJump) {
        reviewsJump.addEventListener('click', function () {
          var el = document.getElementById('reviews');
          if (!el) return;
          var top = el.getBoundingClientRect().top + window.scrollY - 80;
          window.scrollTo({ top: top, behavior: 'smooth' });
        });
      }

      var stickyJump = sticky ? sticky.querySelector('[data-pdp-sticky-jump]') : null;
      if (stickyJump) {
        stickyJump.addEventListener('click', function () {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }

      var copyBtn = pdp.querySelector('[data-pdp-copy-link]');
      var copiedEl = pdp.querySelector('[data-pdp-copied]');
      if (copyBtn) {
        copyBtn.addEventListener('click', function () {
          var url = window.location.href;
          if (navigator.clipboard) navigator.clipboard.writeText(url).catch(function () {});
          if (copiedEl) {
            copiedEl.hidden = false;
            copiedEl.textContent = i18n.copied;
            setTimeout(function () { copiedEl.hidden = true; }, 1800);
          }
        });
      }

      var buyRow = pdp.querySelector('.pt-pdp-actions');
      if (sticky && buyRow && 'IntersectionObserver' in window) {
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            sticky.classList.toggle('is-on', !entry.isIntersecting && entry.boundingClientRect.top < 0);
          });
        }, { threshold: 0 });
        observer.observe(buyRow);
      }
    });
  })();
{% endjavascript %}


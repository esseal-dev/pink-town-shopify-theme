{% comment %}
  This section is used in the product template to render the product page
  with media gallery, buy box, variant picker, details, and related products.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/product
{% endcomment %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign on_sale = false
  if current_variant.compare_at_price > current_variant.price
    assign on_sale = true
  endif
  assign savings_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price
  assign savings_amount = current_variant.compare_at_price | minus: current_variant.price
  assign media_position = section.settings.media_position | default: 'left'

  assign initial_media = current_variant.featured_media | default: product.featured_media
  if initial_media == blank and product.media.size > 0
    assign initial_media = product.media.first
  endif

  assign has_model = false
  for media in product.media
    if media.media_type == 'model'
      assign has_model = true
    endif
  endfor

  assign related_source = product.collections.first

  assign show_stock = false
  if section.settings.show_stock_countdown and current_variant.inventory_management == 'shopify' and current_variant.inventory_policy != 'continue'
    if current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= section.settings.stock_threshold
      assign show_stock = true
    endif
  endif
-%}

<div class="pt-pdp full-width" id="pt-pdp-{{ section.id }}" data-pdp
     data-has-model="{{ has_model }}"
     data-product-title="{{ product.title | escape }}"
     data-i-added-to-bag="{{ 'products.added_to_bag_html' | t: title: '%%TITLE%%' | escape }}"
     data-i-add-error="{{ 'products.add_error' | t | escape }}"
     data-stock-threshold="{{ section.settings.stock_threshold }}"
     data-show-stock="{{ section.settings.show_stock_countdown }}"
     data-i-add-to-cart="{{ 'products.add_to_cart' | t }}"
     data-i-sold-out="{{ 'products.sold_out' | t }}"
     data-i-finish-html="{{ 'products.finish_html' | t: value: '%%VALUE%%' | escape }}"
     data-i-size-selected-html="{{ 'products.size_selected_html' | t: label: '%%LABEL%%', value: '%%VALUE%%' | escape }}"
     data-i-size-label="{{ 'products.size' | t }}"
     data-i-length-label="{{ 'products.length' | t }}"
     data-i-stock-low-html="{{ 'products.stock_low_html' | t: count: '%%COUNT%%' | escape }}"
     data-i-copied="{{ 'products.share_copied' | t }}">

  <div class="pt-pdp-top">
    <nav class="pt-crumb" aria-label="{{ 'general.accessibility.nav_left' | t }}">
      <a href="{{ routes.root_url }}">{{ 'sections.collection.breadcrumb_home' | t }}</a>
      <span>/</span>
      <a href="{{ routes.all_products_collection_url }}">{{ 'sections.collection.breadcrumb_shop' | t }}</a>
      {%- if related_source -%}
        <span>/</span>
        <a href="{{ related_source.url }}">{{ related_source.title }}</a>
      {%- endif -%}
      <span>/</span>
      <b>{{ product.title }}</b>
    </nav>

    <div class="pt-pdp-wrap pt-pdp--{{ media_position }}">
      <div class="pt-pdp-media">
        <div class="pt-pdp-main" data-pdp-main data-media-id="{{ initial_media.id }}">
          {%- if initial_media -%}
            {%- case initial_media.media_type -%}
              {%- when 'image' -%}
                {{ initial_media | image_url: width: 1200 | image_tag: class: 'pt-ph-img', loading: 'eager', alt: initial_media.alt | default: product.title }}
              {%- when 'external_video' -%}
                {{ initial_media | external_video_tag: class: 'pt-pdp-media-embed' }}
              {%- when 'video' -%}
                {{ initial_media | video_tag: class: 'pt-pdp-media-embed', controls: true }}
              {%- when 'model' -%}
                {{ initial_media | model_viewer_tag: class: 'pt-pdp-media-embed' }}
            {%- endcase -%}
          {%- else -%}
            <span class="pt-ph-lbl">{{ product.title | truncate: 24 }}</span>
          {%- endif -%}
          {%- if on_sale -%}
            <span class="pt-pdp-tag">{{ 'products.save_pct' | t: pct: savings_pct }}</span>
          {%- elsif product.tags contains 'bestseller' or product.tags contains 'Bestseller' -%}
            <span class="pt-pdp-tag">{{ 'products.tag_bestseller' | t }}</span>
          {%- elsif product.tags contains 'new' or product.tags contains 'New' -%}
            <span class="pt-pdp-tag">{{ 'products.tag_new' | t }}</span>
          {%- endif -%}
        </div>
        {%- if product.media.size > 1 -%}
          <div class="pt-pdp-thumbs" data-pdp-thumbs>
            {%- for media in product.media -%}
              <button type="button" class="pt-pdp-thumb" data-pdp-thumb data-media-id="{{ media.id }}" data-on="{% if media.id == initial_media.id %}1{% else %}0{% endif %}">
                {%- if media.media_type == 'image' -%}
                  {{ media | image_url: width: 160 | image_tag: alt: media.alt | default: product.title }}
                {%- else -%}
                  {{ media.preview_image | image_url: width: 160 | image_tag: alt: media.alt | default: product.title }}
                  <span class="pt-pdp-thumb-badge" aria-hidden="true">
                    {%- if media.media_type == 'model' -%}
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3l8 4.5v9L12 21l-8-4.5v-9L12 3z"/><path d="M12 12l8-4.5M12 12v9M12 12L4 7.5"/></svg>
                    {%- else -%}
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                    {%- endif -%}
                  </span>
                {%- endif -%}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
        <div hidden data-pdp-media-templates>
          {%- for media in product.media -%}
            <template data-pdp-media-tpl data-media-id="{{ media.id }}">
              {%- case media.media_type -%}
                {%- when 'image' -%}
                  {{ media | image_url: width: 1200 | image_tag: class: 'pt-ph-img', loading: 'lazy', alt: media.alt | default: product.title }}
                {%- when 'external_video' -%}
                  {{ media | external_video_tag: class: 'pt-pdp-media-embed' }}
                {%- when 'video' -%}
                  {{ media | video_tag: class: 'pt-pdp-media-embed', controls: true }}
                {%- when 'model' -%}
                  {{ media | model_viewer_tag: class: 'pt-pdp-media-embed' }}
              {%- endcase -%}
            </template>
          {%- endfor -%}
        </div>
      </div>

      <div class="pt-pdp-info">
        {%- assign product_form_id = 'pt-product-form-' | append: section.id -%}
        {%- form 'product', product, id: product_form_id -%}
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'vendor' -%}
                <div class="pt-pdp-vendor-row" {{ block.shopify_attributes }}>
                  {%- if product.vendor != blank -%}
                    <span class="pt-pdp-vendor">{{ product.vendor }}</span>
                  {%- endif -%}
                  {%- if product.type != blank -%}
                    <span class="pt-card-cat">{{ product.type | escape }}</span>
                  {%- endif -%}
                </div>

              {%- when 'title' -%}
                <h1 class="pt-pdp-title" {{ block.shopify_attributes }}>{{ product.title }}</h1>

              {%- when 'price' -%}
                <div {{ block.shopify_attributes }}>
                  <div class="pt-pdp-price" data-pdp-price>
                    <span class="pt-price-now">{{ current_variant.price | money }}</span>
                    {%- if on_sale -%}
                      <span class="pt-price-was">{{ current_variant.compare_at_price | money }}</span>
                      <span class="pt-price-save">{{ 'products.save_pct' | t: pct: savings_pct }}</span>
                    {%- endif -%}
                  </div>
                  {%- render 'unit-price', item: current_variant -%}
                  {%- if on_sale -%}
                    <p class="pt-pdp-cap" data-pdp-cap>{{ 'products.savings_caption_html' | t: amount: savings_amount | money }}</p>
                  {%- endif -%}
                  <div class="pt-pdp-terms">{{ form | payment_terms }}</div>
                </div>

              {%- when 'variant_picker' -%}
                <div {{ block.shopify_attributes }}>
                  {%- unless product.has_only_default_variant -%}
                    <div class="pt-pdp-options">
                      {%- for option in product.options_with_values -%}
                        {%- liquid
                          assign opt_down = option.name | downcase
                          assign current_value = current_variant.options[forloop.index0]
                          assign is_swatch = false
                          if opt_down contains 'color' or opt_down contains 'finish'
                            assign is_swatch = true
                          endif
                          assign first_value = option.values | first
                          if first_value.swatch
                            assign is_swatch = true
                          endif
                          if opt_down contains 'size'
                            assign opt_label = 'products.size' | t
                          elsif opt_down contains 'length'
                            assign opt_label = 'products.length' | t
                          else
                            assign opt_label = option.name
                          endif
                        -%}
                        <div class="pt-pdp-field" data-pdp-field data-opt-index="{{ forloop.index0 }}" data-opt-name="{{ option.name | escape }}">
                          <span class="pt-pdp-flabel" data-pdp-flabel>
                            {%- if is_swatch -%}
                              {{ 'products.finish_html' | t: value: current_value }}
                            {%- else -%}
                              {{ 'products.size_selected_html' | t: label: opt_label, value: current_value }}
                            {%- endif -%}
                          </span>
                          <div class="{% if is_swatch %}pt-pdp-colors{% else %}pt-pdp-pills{% endif %}">
                            {%- for value in option.values -%}
                              {%- liquid
                                assign val_name = value.name | default: value
                                assign swatch_style = ''
                                if value.swatch.color
                                  assign swatch_style = 'background:rgb(' | append: value.swatch.color.rgb | append: ')'
                                elsif value.swatch.image
                                  assign swatch_img = value.swatch.image | image_url: width: 80
                                  assign swatch_style = 'background-image:url(' | append: swatch_img | append: ');background-size:cover'
                                endif
                              -%}
                              <button type="button"
                                      class="{% if is_swatch %}pt-pdp-color{% else %}pt-pdp-pill{% endif %}"
                                      data-pdp-option data-opt-index="{{ forloop.parentloop.index0 }}" data-opt-value="{{ val_name | escape }}"
                                      data-on="{% if val_name == current_value %}1{% else %}0{% endif %}"
                                      title="{{ val_name | escape }}">
                                {%- if is_swatch -%}
                                  {%- if swatch_style != '' -%}
                                    <span style="{{ swatch_style }}"></span>
                                  {%- else -%}
                                    <span style="background:{% render 'finish-hex', name: val_name %}"></span>
                                  {%- endif -%}
                                {%- else -%}
                                  {{ val_name }}
                                {%- endif -%}
                              </button>
                            {%- endfor -%}
                          </div>
                        </div>
                      {%- endfor -%}
                    </div>
                  {%- endunless -%}

                  <input type="hidden" name="id" value="{{ current_variant.id }}" data-pdp-variant-select>
                  <noscript>
                    {%- unless product.has_only_default_variant -%}
                      <label class="pt-pdp-flabel" for="pt-noscript-variant-{{ section.id }}">{{ 'products.variant_label' | t }}</label>
                      <select id="pt-noscript-variant-{{ section.id }}" name="id" class="pt-pdp-noscript-select">
                        {%- for variant in product.variants -%}
                          <option value="{{ variant.id }}" {% if variant.id == current_variant.id %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>
                            {{ variant.title }} — {{ variant.price | money }}
                          </option>
                        {%- endfor -%}
                      </select>
                    {%- endunless -%}
                  </noscript>

                  <script type="application/json" data-pdp-variants>{{ product.variants | json }}</script>

                  <div class="pt-pdp-stock" data-pdp-stock {% unless show_stock %}hidden{% endunless %}>
                    <div class="pt-pdp-stock-bar"><i data-pdp-stock-bar></i></div>
                    <span data-pdp-stock-msg>{{ 'products.stock_low_html' | t: count: current_variant.inventory_quantity }}</span>
                  </div>
                </div>

              {%- when 'buy_buttons' -%}
                <div {{ block.shopify_attributes }}>
                  {%- if product.selling_plan_groups.size > 0 -%}
                    <div class="pt-pdp-plans">
                      <label class="pt-pdp-flabel" for="pt-plan-{{ section.id }}">{{ 'products.purchase_options' | t }}</label>
                      <select id="pt-plan-{{ section.id }}" name="selling_plan" class="pt-pdp-plan-select" data-pdp-plan>
                        {%- unless product.requires_selling_plan -%}
                          <option value="">{{ 'products.one_time_purchase' | t }}</option>
                        {%- endunless -%}
                        {%- for group in product.selling_plan_groups -%}
                          <optgroup label="{{ group.name | escape }}">
                            {%- for plan in group.selling_plans -%}
                              <option value="{{ plan.id }}">{{ plan.name | escape }}</option>
                            {%- endfor -%}
                          </optgroup>
                        {%- endfor -%}
                      </select>
                    </div>
                  {%- endif -%}

                  {%- if product.gift_card? -%}
                    <div class="pt-gift-recipient">
                      <input type="checkbox" id="pt-gift-{{ section.id }}" class="pt-gift-toggle"
                             name="properties[__shopify_send_as_a_gift]" value="on"
                             {% if form.errors %}checked{% endif %}>
                      <label for="pt-gift-{{ section.id }}" class="pt-gift-label">{{ 'products.gift_recipient_label' | t }}</label>
                      <div class="pt-gift-fields">
                        <label>{{ 'products.gift_recipient_email' | t }}
                          <input type="email" name="properties[Recipient email]" value="{{ form.email }}">
                        </label>
                        <label>{{ 'products.gift_recipient_name' | t }}
                          <input type="text" name="properties[Recipient name]" value="{{ form.name }}">
                        </label>
                        <label>{{ 'products.gift_recipient_message' | t }}
                          <textarea name="properties[Message]" maxlength="200" rows="2">{{ form.message }}</textarea>
                        </label>
                        <label>{{ 'products.gift_recipient_send_on' | t }}
                          <input type="date" name="properties[Send on]" value="{{ form.send_on }}">
                        </label>
                        {%- if form.errors -%}
                          <div class="pt-gift-errors" role="alert">
                            {%- for field in form.errors -%}
                              <p>{{ form.errors.messages[field] }}</p>
                            {%- endfor -%}
                          </div>
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endif -%}

                  <div class="pt-pdp-actions">
                    <div class="pt-qty pt-pdp-qty">
                      <button type="button" data-pdp-qty-dec aria-label="{{ 'cart.decrease' | t }}">&minus;</button>
                      <input type="number" name="quantity" value="1" min="1" inputmode="numeric" class="pt-qty-input" data-pdp-qty aria-label="{{ 'cart.quantity_label' | t }}">
                      <button type="button" data-pdp-qty-inc aria-label="{{ 'cart.increase' | t }}">+</button>
                    </div>
                    <button type="submit" name="add" class="pt-btn pt-btn--solid pt-pdp-add" data-pdp-add {% unless current_variant.available %}disabled{% endunless %}>
                      {%- if current_variant.available -%}{{ 'products.add_to_cart' | t }} &middot; {{ current_variant.price | money }}{%- else -%}{{ 'products.sold_out' | t }}{%- endif -%}
                    </button>
                  </div>

                  {%- if block.settings.show_dynamic_checkout -%}
                    <div class="pt-pdp-dynamic" data-pdp-dynamic {% unless current_variant.available %}hidden{% endunless %}>
                      {{ form | payment_button }}
                    </div>
                  {%- endif -%}

                  <div class="pt-pdp-pickup" data-pdp-pickup data-product-url="{{ product.url }}"></div>
                </div>

              {%- when 'description' -%}
                {%- if product.description != blank -%}
                  <div class="pt-pdp-p pt-pdp-desc-block" {{ block.shopify_attributes }}>{{ product.description }}</div>
                {%- endif -%}

              {%- when 'perk' -%}
                {%- if block.settings.text != blank -%}
                  <div class="pt-pdp-perk" {{ block.shopify_attributes }}>
                    <span class="pt-pdp-perk-ic">&#10022;</span>{{ block.settings.text | escape }}
                  </div>
                {%- endif -%}

              {%- when '@app' -%}
                <div class="pt-pdp-app-block" {{ block.shopify_attributes }}>
                  {%- render block -%}
                </div>
            {%- endcase -%}
          {%- endfor -%}

          {%- liquid
            assign has_addons = false
            for block in section.blocks
              if block.type == 'addon' and block.settings.product != blank
                assign has_addons = true
              endif
            endfor
          -%}
          {%- if has_addons -%}
            <div class="pt-pdp-addons">
              <h3 class="pt-pdp-addons-h">{{ section.settings.addons_heading | escape }}</h3>
              <div class="pt-pdp-addon-list">
                {%- for block in section.blocks -%}
                  {%- if block.type == 'addon' and block.settings.product != blank -%}
                    {%- liquid
                      assign addon = block.settings.product
                      assign addon_variant = addon.selected_or_first_available_variant
                    -%}
                    <label class="pt-pdp-addon" data-pdp-addon data-variant-id="{{ addon_variant.id }}" {{ block.shopify_attributes }}>
                      <input type="checkbox" data-pdp-addon-check {% unless addon_variant.available %}disabled{% endunless %}>
                      <span class="pt-pdp-addon-box"></span>
                      <span class="pt-pdp-addon-media">
                        {%- if addon.featured_image -%}
                          {{ addon.featured_image | image_url: width: 160 | image_tag: class: 'pt-ph-img', loading: 'lazy', alt: addon.title }}
                        {%- else -%}
                          <span class="pt-ph-lbl">{{ addon.title | truncate: 16 }}</span>
                        {%- endif -%}
                      </span>
                      <span class="pt-pdp-addon-info">
                        <b>{{ addon.title | escape }}</b>
                        <span class="pt-pdp-addon-price">
                          {%- if addon_variant.available -%}+ {{ addon_variant.price | money }}{%- else -%}{{ 'products.sold_out' | t }}{%- endif -%}
                        </span>
                      </span>
                    </label>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        {%- endform -%}

        {%- if section.settings.show_share -%}
          <div class="pt-pdp-share">
            <span class="pt-pdp-share-lbl">{{ 'products.share_label' | t }}</span>
            <button type="button" class="pt-pdp-share-btn" data-pdp-copy-link aria-label="{{ 'products.share_copy_link' | t }}">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 15l6-6M11 6l1-1a4 4 0 0 1 6 6l-1 1M13 18l-1 1a4 4 0 0 1-6-6l1-1" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <a class="pt-pdp-share-btn" href="https://pinterest.com/pin/create/button/?url={{ canonical_url | url_encode }}&media={{ product.featured_image | image_url: width: 1200 | prepend: 'https:' | url_encode }}&description={{ product.title | url_encode }}" target="_blank" rel="noopener" aria-label="{{ 'products.share_pinterest' | t }}"><b>P</b></a>
            <a class="pt-pdp-share-btn" href="https://www.facebook.com/sharer.php?u={{ canonical_url | url_encode }}" target="_blank" rel="noopener" aria-label="{{ 'products.share_facebook' | t }}"><b>f</b></a>
            <a class="pt-pdp-share-btn" href="mailto:?subject={{ product.title | url_encode }}&body={{ canonical_url | url_encode }}" aria-label="{{ 'products.share_email' | t }}">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M4 7l8 6 8-6"/></svg>
            </a>
            <span class="pt-pdp-share-copied" data-pdp-copied hidden>{{ 'products.share_copied' | t }}</span>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- liquid
    assign has_accordion = false
    for block in section.blocks
      if block.type == 'accordion_item'
        assign has_accordion = true
      endif
    endfor
    assign highlight_lines = section.settings.highlights | newline_to_br | split: '<br />'
  -%}
  {%- if has_accordion or section.settings.highlights != blank -%}
    <section class="pt-pdp-sec">
      <div class="pt-pdp-desc-grid">
        <div>
          {%- if section.settings.details_heading != blank -%}
            <h2 class="pt-pdp-h">{{ section.settings.details_heading | escape }}</h2>
          {%- endif -%}
          {%- if highlight_lines.size > 0 -%}
            <ul class="pt-pdp-highlights">
              {%- for line in highlight_lines -%}
                {%- assign line_trimmed = line | strip -%}
                {%- unless line_trimmed == blank -%}
                  <li>
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="var(--pt-accent)" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
                    {{ line_trimmed }}
                  </li>
                {%- endunless -%}
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>

        {%- if has_accordion -%}
          <div class="pt-pdp-acc" data-pdp-acc>
            {%- for block in section.blocks -%}
              {%- if block.type == 'accordion_item' -%}
                {%- if block.settings.content == blank and request.design_mode != true -%}{%- continue -%}{%- endif -%}
                <div class="pt-pdp-acc-item" data-pdp-acc-item data-open="0" {{ block.shopify_attributes }}>
                  <button type="button" class="pt-pdp-acc-q" data-pdp-acc-toggle aria-expanded="false">
                    {{ block.settings.title | escape }}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg>
                  </button>
                  <div class="pt-pdp-acc-a-wrap">
                    <div class="pt-pdp-acc-a-inner">
                      <div class="pt-pdp-acc-a">{{ block.settings.content }}</div>
                    </div>
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </section>
  {%- endif -%}

</div>

<div class="pt-pdp-sticky" data-pdp-sticky>
  <div class="pt-pdp-sticky-in">
    <button type="button" class="pt-pdp-sticky-prod" data-pdp-sticky-jump>
      <span class="pt-pdp-sticky-img" data-pdp-sticky-img>
        {%- if current_variant.featured_image -%}
          {{ current_variant.featured_image | image_url: width: 100 | image_tag: class: 'pt-ph-img', alt: product.title }}
        {%- elsif product.featured_image -%}
          {{ product.featured_image | image_url: width: 100 | image_tag: class: 'pt-ph-img', alt: product.title }}
        {%- endif -%}
      </span>
      <span class="pt-pdp-sticky-meta">
        <b>{{ product.title | escape }}</b>
        <i data-pdp-sticky-variant>{% unless current_variant.title == 'Default Title' %}{{ current_variant.title | escape }}{% endunless %}</i>
      </span>
    </button>
    <span class="pt-pdp-sticky-price" data-pdp-sticky-price>
      <span class="pt-price-now">{{ current_variant.price | money }}</span>
      {%- if on_sale -%}<span class="pt-price-was">{{ current_variant.compare_at_price | money }}</span>{%- endif -%}
    </span>
    <button type="button" class="pt-btn pt-btn--solid pt-pdp-sticky-add" data-pdp-sticky-add {% unless current_variant.available %}disabled{% endunless %}>
      {%- if current_variant.available -%}{{ 'products.add_to_cart' | t }} &middot; {{ current_variant.price | money }}{%- else -%}{{ 'products.sold_out' | t }}{%- endif -%}
    </button>
  </div>
</div>

{% stylesheet %}
  .pt-visually-hidden { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }

  .pt-pdp { width: 100%; }
  .pt-pdp-top { max-width: var(--pt-wrap); margin: 0 auto; padding: 26px 32px 16px; }
  .pt-pdp-wrap { display: grid; grid-template-columns: 1.08fr .92fr; gap: 56px; align-items: flex-start; margin-top: 8px; }
  .pt-pdp--right .pt-pdp-media { order: 2; }
  .pt-pdp--right .pt-pdp-info { order: 1; }

  .pt-pdp-info { position: sticky; top: 88px; align-self: start; font-family: var(--pt-font-body); }
  .pt-pdp-main { position: relative; aspect-ratio: 1/1; border-radius: var(--pt-radius); overflow: hidden; background: var(--pt-accent-soft); box-shadow: var(--pt-shadow-sm); display: flex; align-items: center; justify-content: center; }
  .pt-pdp-main .pt-ph-img { transition: transform .5s ease; }
  .pt-pdp-main:hover .pt-ph-img { transform: scale(1.05); }
  .pt-pdp-main .pt-ph-lbl { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); }
  .pt-pdp-tag { position: absolute; top: 14px; left: 14px; z-index: 2; background: rgba(255,255,255,.94); color: var(--pt-accent-deep); font-size: 11px; font-weight: 800; letter-spacing: .06em; text-transform: uppercase; padding: 6px 12px; border-radius: 999px; font-family: var(--pt-font-body); }
  .pt-pdp-thumbs { display: flex; gap: 10px; margin-top: 12px; flex-wrap: wrap; }
  .pt-pdp-thumb { position: relative; width: 76px; aspect-ratio: 1/1; border-radius: 12px; overflow: hidden; border: none; padding: 0; cursor: pointer; box-shadow: 0 0 0 1px var(--pt-line); }
  .pt-pdp-thumb[data-on="1"] { box-shadow: 0 0 0 2px var(--pt-accent-deep); }
  .pt-pdp-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .pt-pdp-thumb-badge { position: absolute; right: 4px; bottom: 4px; width: 18px; height: 18px; border-radius: 50%; background: rgba(20,10,14,.65); color: #fff; display: grid; place-items: center; }
  .pt-pdp-media-embed { position: absolute; inset: 0; width: 100%; height: 100%; }
  .pt-pdp-main model-viewer.pt-pdp-media-embed { --poster-color: transparent; }

  .pt-pdp-vendor { display: block; font-size: 12px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--pt-accent-deep); margin-bottom: 8px; }
  .pt-pdp-info .pt-card-cat { display: block; margin-top: 4px; }
  .pt-pdp-title { font-family: var(--pt-font-head); font-size: clamp(2.2rem, 3.4vw, 3rem); line-height: 1.08; letter-spacing: -.01em; margin-top: 6px; }
  .pt-pdp-price { display: flex; align-items: center; gap: 11px; margin-top: 18px; }
  .pt-pdp-price .pt-price-now { font-size: 26px; font-weight: 800; color: var(--pt-ink); }
  .pt-pdp-price .pt-price-was { font-size: 16px; color: var(--pt-ink-faint); text-decoration: line-through; }
  .pt-pdp-cap { font-size: 12.5px; line-height: 1.7; color: var(--pt-ink-soft); margin: 10px 0 0; }
  .pt-pdp-cap b { color: var(--pt-accent-deep); }
  .pt-pdp-terms:empty { display: none; }
  .pt-pdp-terms { margin-top: 8px; font-size: 12.5px; color: var(--pt-ink-soft); }

  .pt-pdp-options { margin-top: 24px; display: flex; flex-direction: column; gap: 24px; }
  .pt-pdp-flabel { font-size: 13px; font-weight: 600; color: var(--pt-ink); display: block; margin-bottom: 10px; }
  .pt-pdp-flabel b { color: var(--pt-accent-deep); }
  .pt-pdp-colors { display: flex; flex-wrap: wrap; gap: 10px; }
  .pt-pdp-color { width: 38px; height: 38px; border-radius: 50%; border: none; padding: 3px; cursor: pointer; background: none; box-shadow: inset 0 0 0 1.5px var(--pt-line); transition: box-shadow .18s; }
  .pt-pdp-color span { display: block; width: 100%; height: 100%; border-radius: 50%; box-shadow: inset 0 0 0 1px rgba(0,0,0,.08); }
  .pt-pdp-color[data-on="1"] { box-shadow: inset 0 0 0 2px var(--pt-accent-deep); }
  .pt-pdp-pills { display: flex; flex-wrap: wrap; gap: 9px; }
  .pt-pdp-pill { min-width: 48px; height: 42px; padding: 0 14px; border: 1px solid var(--pt-line); background: #fff; border-radius: 10px; font-family: var(--pt-font-body); font-size: 13.5px; font-weight: 600; color: var(--pt-ink); cursor: pointer; transition: all .18s; }
  .pt-pdp-pill:hover { border-color: var(--pt-accent); }
  .pt-pdp-pill[data-on="1"] { background: var(--pt-accent-deep); color: #fff; border-color: var(--pt-accent-deep); }
  .pt-pdp-pill[disabled] { opacity: .4; cursor: not-allowed; text-decoration: line-through; }

  .pt-pdp-stock { margin-top: 24px; }
  .pt-pdp-stock-bar { height: 6px; border-radius: 999px; background: var(--pt-accent-soft); overflow: hidden; margin-bottom: 8px; }
  .pt-pdp-stock-bar i { display: block; height: 100%; border-radius: 999px; background: linear-gradient(90deg, var(--pt-accent), var(--pt-accent-deep)); }
  .pt-pdp-stock span { font-size: 12.5px; color: var(--pt-ink-soft); }
  .pt-pdp-stock span b { color: var(--pt-accent-deep); }

  .pt-pdp-actions { display: flex; gap: 10px; margin-top: 22px; }
  .pt-pdp-qty { flex: none; border-radius: 999px; }
  .pt-pdp-qty button { width: 40px; height: 44px; }
  .pt-pdp-qty span { min-width: 30px; font-size: 15px; }
  .pt-pdp-add { flex: 1; }
  .pt-pdp-add[disabled] { opacity: .55; cursor: not-allowed; transform: none !important; }
  .pt-pdp-vendor-row { display: flex; gap: 10px; align-items: center; }
  .pt-pdp-desc-block { margin-top: 16px; }
  .pt-pdp-perk { display: flex; align-items: center; gap: 9px; font-size: 13px; color: var(--pt-ink-soft); font-family: var(--pt-font-body); margin-top: 8px; }
  .pt-pdp-perk .pt-pdp-perk-ic { color: var(--pt-accent); }
  .pt-pdp-plans { margin-top: 14px; }
  .pt-pdp-plan-select, .pt-pdp-noscript-select { display: block; width: 100%; margin-top: 8px; font-family: var(--pt-font-body); font-size: 14px; color: var(--pt-ink); border: 1px solid var(--pt-line); background: #fff; border-radius: 12px; padding: 11px 14px; }
  .pt-gift-recipient { margin-top: 16px; font-family: var(--pt-font-body); }
  .pt-gift-toggle { position: absolute; opacity: 0; }
  .pt-gift-label { display: inline-flex; align-items: center; gap: 9px; font-size: 13.5px; font-weight: 600; color: var(--pt-ink); cursor: pointer; }
  .pt-gift-label::before { content: ''; width: 18px; height: 18px; border: 1.5px solid var(--pt-line); border-radius: 5px; background: #fff; transition: all .15s; flex: none; }
  .pt-gift-toggle:checked + .pt-gift-label::before { background: var(--pt-accent); border-color: var(--pt-accent); box-shadow: inset 0 0 0 3px #fff; }
  .pt-gift-toggle:focus-visible + .pt-gift-label::before { outline: 2px solid var(--pt-accent); outline-offset: 2px; }
  .pt-gift-fields { display: none; margin-top: 12px; flex-direction: column; gap: 10px; }
  .pt-gift-toggle:checked ~ .pt-gift-fields { display: flex; }
  .pt-gift-fields label { font-size: 12.5px; font-weight: 600; color: var(--pt-ink-soft); display: flex; flex-direction: column; gap: 5px; }
  .pt-gift-fields input, .pt-gift-fields textarea { border: 1px solid var(--pt-line); border-radius: 10px; background: #fff; font-family: var(--pt-font-body); font-size: 13.5px; color: var(--pt-ink); padding: 10px 12px; }
  .pt-gift-fields input:focus, .pt-gift-fields textarea:focus { outline: none; border-color: var(--pt-accent); }
  .pt-gift-errors { color: #b3261e; font-size: 12.5px; }
  .pt-pdp-dynamic { margin-top: 12px; }
  .pt-pickup { margin-top: 16px; display: flex; flex-direction: column; gap: 10px; font-family: var(--pt-font-body); }
  .pt-pickup-loc { display: flex; gap: 10px; align-items: flex-start; }
  .pt-pickup-ic { flex: none; margin-top: 2px; }
  .pt-pickup-ic--ok { color: #2e7d32; }
  .pt-pickup-ic--no { color: var(--pt-ink-faint); }
  .pt-pickup-txt { display: flex; flex-direction: column; gap: 2px; font-size: 12.5px; color: var(--pt-ink-soft); }
  .pt-pickup-txt b { color: var(--pt-ink); font-size: 13px; }
  .pt-pdp-dynamic .shopify-payment-button__button--unbranded { background: transparent; border: 1.5px solid var(--pt-accent); color: var(--pt-accent-deep); font-family: var(--pt-font-body); font-weight: 700; font-size: 14px; border-radius: 999px; padding: 13px 24px; width: 100%; transition: background .2s, color .2s; }
  .pt-pdp-dynamic .shopify-payment-button__button--unbranded:hover { background: var(--pt-accent); color: var(--pt-accent-contrast, #fff); }
  .pt-pdp-dynamic .shopify-payment-button__button--branded { border-radius: 999px; overflow: hidden; }
  .pt-pdp-dynamic .shopify-payment-button__more-options { font-family: var(--pt-font-body); color: var(--pt-ink-soft); }
  .pt-pdp-app-block { margin-top: 12px; }
  .pt-pdp-shake { animation: ptPdpShake .4s; }
  @keyframes ptPdpShake { 0%,100% { transform: translateX(0); } 25% { transform: translateX(-5px); } 75% { transform: translateX(5px); } }

  .pt-pdp-addons { margin-top: 22px; padding: 18px; background: var(--pt-bg-tint); border-radius: var(--pt-radius); }
  .pt-pdp-addons-h { font-family: var(--pt-font-body); font-size: 13px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; color: var(--pt-accent-deep); margin-bottom: 14px; }
  .pt-pdp-addon-list { display: flex; flex-direction: column; gap: 10px; }
  .pt-pdp-addon { display: flex; align-items: center; gap: 12px; cursor: pointer; background: #fff; border: 1px solid var(--pt-line); border-radius: 14px; padding: 10px 14px; transition: border-color .18s; }
  .pt-pdp-addon:hover { border-color: var(--pt-accent); }
  .pt-pdp-addon input { position: absolute; opacity: 0; width: 0; height: 0; }
  .pt-pdp-addon-box { width: 19px; height: 19px; border: 1.5px solid var(--pt-line); border-radius: 6px; flex: none; display: grid; place-items: center; transition: all .18s; }
  .pt-pdp-addon input:checked + .pt-pdp-addon-box { background: var(--pt-accent-deep); border-color: var(--pt-accent-deep); }
  .pt-pdp-addon input:checked + .pt-pdp-addon-box::after { content: ''; width: 9px; height: 5px; border: 2px solid #fff; border-top: 0; border-right: 0; transform: rotate(-45deg) translateY(-1px); }
  .pt-pdp-addon input:disabled + .pt-pdp-addon-box { opacity: .4; }
  .pt-pdp-addon input:disabled ~ * { opacity: .5; }
  .pt-pdp-addon-media { flex: none; width: 44px; height: 44px; border-radius: 10px; overflow: hidden; position: relative; background: var(--pt-accent-soft); display: flex; align-items: center; justify-content: center; }
  .pt-pdp-addon-media .pt-ph-lbl { font-size: 8px; padding: 3px 5px; }
  .pt-pdp-addon-info { flex: 1; display: flex; align-items: center; justify-content: space-between; gap: 10px; font-size: 13.5px; }
  .pt-pdp-addon-info b { font-weight: 600; color: var(--pt-ink); }
  .pt-pdp-addon-price { color: var(--pt-accent-deep); font-weight: 700; white-space: nowrap; }

  .pt-pdp-perks { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 18px; margin-top: 26px; padding-top: 22px; border-top: 1px solid var(--pt-line); }
  .pt-pdp-perks li { display: flex; align-items: center; gap: 9px; font-size: 12.5px; color: var(--pt-ink-soft); }
  .pt-pdp-perk-ic { width: 26px; height: 26px; flex: none; display: grid; place-items: center; border-radius: 50%; background: var(--pt-accent-soft); color: var(--pt-accent-deep); font-size: 13px; }

  .pt-pdp-share { display: flex; align-items: center; gap: 10px; margin-top: 24px; }
  .pt-pdp-share-lbl { font-size: 12px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--pt-ink-faint); margin-right: 2px; }
  .pt-pdp-share-btn { width: 34px; height: 34px; border-radius: 50%; border: 1px solid var(--pt-line); background: #fff; color: var(--pt-ink-soft); display: grid; place-items: center; cursor: pointer; transition: all .2s; font-family: var(--pt-font-head); font-size: 15px; text-decoration: none; }
  .pt-pdp-share-btn:hover { border-color: var(--pt-accent); color: var(--pt-accent-deep); transform: translateY(-1px); }
  .pt-pdp-share-copied { font-size: 12.5px; color: var(--pt-accent-deep); font-weight: 600; }

  .pt-pdp-acc { border-top: 1px solid var(--pt-line); }
  .pt-pdp-acc-item { border-bottom: 1px solid var(--pt-line); }
  .pt-pdp-acc-q { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 16px; text-align: left; border: none; background: none; font-family: var(--pt-font-head); font-size: 20px; color: var(--pt-ink); padding: 18px 0; cursor: pointer; }
  .pt-pdp-acc-q svg { color: var(--pt-accent-deep); transition: transform .25s; flex: none; }
  .pt-pdp-acc-item[data-open="1"] .pt-pdp-acc-q svg { transform: rotate(45deg); }
  .pt-pdp-acc-a-wrap { display: grid; grid-template-rows: 0fr; transition: grid-template-rows .3s ease; }
  .pt-pdp-acc-item[data-open="1"] .pt-pdp-acc-a-wrap { grid-template-rows: 1fr; }
  .pt-pdp-acc-a-inner { overflow: hidden; }
  .pt-pdp-acc-a { font-size: 14px; line-height: 1.65; color: var(--pt-ink-soft); margin: 0 0 20px; max-width: 60ch; }

  .pt-pdp-sec { max-width: var(--pt-wrap); margin: 0 auto; padding: 70px 32px; font-family: var(--pt-font-body); }
  .pt-pdp-sec--tint { width: 100%; max-width: none; margin: 0; background: radial-gradient(120% 80% at 50% 0%, var(--pt-accent-soft) 0%, transparent 55%), var(--pt-bg-tint); }
  .pt-pdp-sec--tint > * { width: 100%; max-width: var(--pt-wrap); margin-left: auto; margin-right: auto; }
  .pt-pdp-h { font-family: var(--pt-font-head); font-size: clamp(2rem, 3.4vw, 2.8rem); line-height: 1.05; letter-spacing: -.01em; }
  .pt-pdp-h--center { text-align: center; }
  .pt-pdp-desc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: start; }
  .pt-pdp-p { font-size: 16px; line-height: 1.7; color: var(--pt-ink-soft); margin: 18px 0 0; max-width: 46ch; }
  .pt-pdp-p p:not(:last-child) { margin-bottom: 10px; }
  .pt-pdp-highlights { margin-top: 22px; display: flex; flex-direction: column; gap: 12px; }
  .pt-pdp-highlights li { display: flex; align-items: flex-start; gap: 10px; font-size: 14.5px; color: var(--pt-ink); }
  .pt-pdp-highlights svg { margin-top: 3px; flex: none; }

  .pt-prod-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 26px 22px; margin-top: 8px; }
  .pt-card { position: relative; }
  .pt-card-media { position: relative; border-radius: var(--pt-radius); overflow: hidden; aspect-ratio: 1/1; box-shadow: var(--pt-shadow-sm); }
  .pt-card-tag { position: absolute; top: 12px; left: 12px; z-index: 3; background: rgba(255,255,255,.94); color: var(--pt-accent-deep); font-size: 10.5px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; padding: 5px 10px; border-radius: 999px; font-family: var(--pt-font-body); }
  .pt-add { position: absolute; left: 12px; right: 12px; bottom: 12px; z-index: 3; border: none; background: rgba(255,255,255,.96); color: var(--pt-ink); font-family: var(--pt-font-body); font-weight: 700; font-size: 13px; padding: 12px; border-radius: 999px; cursor: pointer; box-shadow: var(--pt-shadow-sm); opacity: 0; transform: translateY(12px); transition: opacity .3s, transform .3s, background .25s, color .25s; text-align: center; }
  .pt-card-media:hover .pt-add { opacity: 1; transform: translateY(0); }
  .pt-add:hover { background: linear-gradient(135deg, var(--pt-accent), var(--pt-accent-deep)); color: #fff; }
  .pt-add.is-added { opacity: 1; transform: translateY(0); background: var(--pt-accent-deep); color: #fff; }
  .pt-add--soldout { opacity: 1; transform: none; background: rgba(255,255,255,.8); color: var(--pt-ink-faint); cursor: default; }
  @media (hover: none) { .pt-add { opacity: 1; transform: none; } }
  .pt-card-info { padding: 15px 2px 0; }
  .pt-card-cat { font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--pt-ink-faint); font-family: var(--pt-font-body); }
  .pt-card-name { font-family: var(--pt-font-head); font-size: 20px; margin: 3px 0 8px; line-height: 1.1; }
  .pt-card-name a { color: inherit; }
  .pt-card-name a:hover { color: var(--pt-accent-deep); }
  .pt-card-price { display: flex; align-items: center; gap: 9px; flex-wrap: wrap; }
  .pt-price-now { font-weight: 800; font-size: 15px; color: var(--pt-ink); font-family: var(--pt-font-body); }
  .pt-price-was { font-size: 13px; color: var(--pt-ink-faint); text-decoration: line-through; font-family: var(--pt-font-body); }
  .pt-price-save { margin-left: auto; font-size: 11px; font-weight: 800; color: var(--pt-accent-deep); background: var(--pt-accent-soft); padding: 3px 8px; border-radius: 999px; white-space: nowrap; font-family: var(--pt-font-body); }

  .pt-pdp-sticky { position: fixed; left: 0; right: 0; bottom: 0; z-index: 90; background: rgba(255,250,251,.95); backdrop-filter: blur(14px) saturate(150%); border-top: 1px solid var(--pt-line); box-shadow: 0 -10px 30px -18px rgba(60,50,55,.4); transform: translateY(110%); transition: transform .35s cubic-bezier(.3,.7,.4,1); }
  .pt-pdp-sticky.is-on { transform: translateY(0); }
  .pt-pdp-sticky-in { max-width: var(--pt-wrap); margin: 0 auto; padding: 12px 32px; display: flex; align-items: center; gap: 18px; }
  .pt-pdp-sticky-prod { display: flex; align-items: center; gap: 12px; border: none; background: none; cursor: pointer; text-align: left; padding: 0; font-family: var(--pt-font-body); min-width: 0; }
  .pt-pdp-sticky-img { position: relative; width: 46px; height: 46px; flex: none; border-radius: 10px; overflow: hidden; background: var(--pt-accent-soft); }
  .pt-pdp-sticky-meta { display: flex; flex-direction: column; min-width: 0; }
  .pt-pdp-sticky-meta b { font-family: var(--pt-font-head); font-size: 18px; line-height: 1.1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .pt-pdp-sticky-meta i { font-size: 12px; color: var(--pt-ink-soft); font-style: normal; }
  .pt-pdp-sticky-price { margin-left: auto; display: flex; align-items: baseline; gap: 8px; }
  .pt-pdp-sticky-price .pt-price-now { font-size: 18px; }
  .pt-pdp-sticky-add { white-space: nowrap; flex: none; }

  @media (max-width: 920px) {
    .pt-pdp-wrap { grid-template-columns: 1fr; gap: 32px; }
    .pt-pdp--right .pt-pdp-media, .pt-pdp--right .pt-pdp-info { order: initial; }
    .pt-pdp-info { position: static; }
    .pt-pdp-desc-grid { grid-template-columns: 1fr; gap: 32px; }
    .pt-prod-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .pt-pdp-top { padding: 18px 20px 8px; }
    .pt-pdp-sec { padding: 50px 20px; }
    .pt-pdp-actions { flex-wrap: wrap; }
    .pt-pdp-add { flex: 1 1 100%; order: -1; }
    .pt-pdp-perks { grid-template-columns: 1fr; }
    .pt-prod-grid { grid-template-columns: repeat(2, 1fr); gap: 18px 12px; }
    .pt-pdp-sticky-in { padding: 10px 16px; gap: 12px; }
    .pt-pdp-sticky-meta { display: none; }
    .pt-pdp-sticky-add { flex: 1; }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    document.querySelectorAll('[data-pdp]').forEach(function (pdp) {
      var variantsScript = pdp.querySelector('[data-pdp-variants]');
      if (!variantsScript) return;
      var variants = JSON.parse(variantsScript.textContent);
      var variantSelect = pdp.querySelector('[data-pdp-variant-select]');
      var fields = Array.prototype.slice.call(pdp.querySelectorAll('[data-pdp-field]'));
      var mainMedia = pdp.querySelector('[data-pdp-main]');
      var thumbs = Array.prototype.slice.call(pdp.querySelectorAll('[data-pdp-thumb]'));
      var priceEl = pdp.querySelector('[data-pdp-price]');
      var addBtn = pdp.querySelector('[data-pdp-add]');
      var dynamicWrap = pdp.querySelector('[data-pdp-dynamic]');
      var qtyEl = pdp.querySelector('[data-pdp-qty]');
      var qtyDec = pdp.querySelector('[data-pdp-qty-dec]');
      var qtyInc = pdp.querySelector('[data-pdp-qty-inc]');
      var stockWrap = pdp.querySelector('[data-pdp-stock]');
      var stockBar = pdp.querySelector('[data-pdp-stock-bar]');
      var stockMsg = pdp.querySelector('[data-pdp-stock-msg]');
      var showStock = pdp.dataset.showStock === 'true';
      var stockThreshold = parseInt(pdp.dataset.stockThreshold, 10) || 0;
      var mediaTemplates = Array.prototype.slice.call(pdp.querySelectorAll('[data-pdp-media-tpl]'));

      if (pdp.dataset.hasModel === 'true' && window.Shopify && Shopify.loadFeatures) {
        Shopify.loadFeatures([{ name: 'model-viewer-ui', version: '1.0', onLoad: function () {} }]);
      }

      var sticky = document.querySelector('[data-pdp-sticky]');
      var stickyImg = sticky ? sticky.querySelector('[data-pdp-sticky-img]') : null;
      var stickyVariant = sticky ? sticky.querySelector('[data-pdp-sticky-variant]') : null;
      var stickyPrice = sticky ? sticky.querySelector('[data-pdp-sticky-price]') : null;
      var stickyAdd = sticky ? sticky.querySelector('[data-pdp-sticky-add]') : null;

      var i18n = {
        addToCart: pdp.dataset.iAddToCart,
        soldOut: pdp.dataset.iSoldOut,
        finishHtml: pdp.dataset.iFinishHtml,
        sizeSelectedHtml: pdp.dataset.iSizeSelectedHtml,
        sizeLabel: pdp.dataset.iSizeLabel,
        lengthLabel: pdp.dataset.iLengthLabel,
        stockLowHtml: pdp.dataset.iStockLowHtml,
        copied: pdp.dataset.iCopied,
        addedToBag: pdp.dataset.iAddedToBag,
        addError: pdp.dataset.iAddError
      };

      var selected = variantSelect
        ? (variants.filter(function (v) { return String(v.id) === variantSelect.value; })[0] || variants[0] || { options: [] }).options.slice()
        : [];
      var qtyVal = 1;

      function money(cents) {
        return window.ptMoney ? window.ptMoney(cents) : '$' + (cents / 100).toFixed(2);
      }

      function findVariant() {
        return variants.filter(function (v) {
          return v.options.every(function (val, i) { return val === selected[i]; });
        })[0] || null;
      }

      function fieldLabelHtml(field) {
        var isSwatch = field.querySelector('.pt-pdp-colors') !== null;
        var i = parseInt(field.dataset.optIndex, 10);
        var value = selected[i];
        if (isSwatch) return i18n.finishHtml.replace('%%VALUE%%', value);
        var optLabel = field.dataset.optLabel;
        return i18n.sizeSelectedHtml.replace('%%LABEL%%', optLabel).replace('%%VALUE%%', value);
      }

      function updateAddButtons(variant) {
        var available = !!(variant && variant.available);
        [addBtn, stickyAdd].forEach(function (btn) {
          if (!btn) return;
          btn.disabled = !available;
          btn.textContent = available ? i18n.addToCart + ' · ' + money(variant.price * qtyVal) : i18n.soldOut;
        });
      }

      function updateStock(variant) {
        if (!stockWrap || !showStock) return;
        var qty = variant ? variant.inventory_quantity : null;
        var tracked = variant && variant.inventory_management === 'shopify' && variant.inventory_policy !== 'continue';
        var show = tracked && qty > 0 && qty <= stockThreshold;
        stockWrap.hidden = !show;
        if (show) {
          if (stockMsg) stockMsg.innerHTML = i18n.stockLowHtml.replace('%%COUNT%%', qty);
          if (stockBar) stockBar.style.width = Math.max(8, (qty / stockThreshold) * 100) + '%';
        }
      }

      function render() {
        var variant = findVariant();

        fields.forEach(function (field) {
          var label = field.querySelector('[data-pdp-flabel]');
          if (label) label.innerHTML = fieldLabelHtml(field);
        });

        if (!variant) {
          updateAddButtons(null);
          if (dynamicWrap) dynamicWrap.hidden = true;
          if (stockWrap) stockWrap.hidden = true;
          return;
        }

        if (priceEl) {
          priceEl.innerHTML = '<span class="pt-price-now">' + money(variant.price) + '</span>' +
            (variant.compare_at_price > variant.price ? '<span class="pt-price-was">' + money(variant.compare_at_price) + '</span>' : '');
        }
        updateAddButtons(variant);
        updateStock(variant);
        if (dynamicWrap) dynamicWrap.hidden = !variant.available;
        if (variantSelect && String(variantSelect.value) !== String(variant.id)) {
          variantSelect.value = variant.id;
          variantSelect.dispatchEvent(new Event('change', { bubbles: true }));
        }
        if (variant.featured_image) {
          setMainImage(variant.featured_image.src, variant.featured_image.id);
        }
        if (stickyImg && variant.featured_image) {
          stickyImg.innerHTML = '<img class="pt-ph-img" src="' + variant.featured_image.src.replace(/(\.\w+)(\?|$)/, '_100x100$1$2') + '" alt="">';
        }
        if (stickyVariant) stickyVariant.textContent = variant.title !== 'Default Title' ? variant.title : '';
        if (stickyPrice) {
          stickyPrice.innerHTML = '<span class="pt-price-now">' + money(variant.price) + '</span>' +
            (variant.compare_at_price > variant.price ? '<span class="pt-price-was">' + money(variant.compare_at_price) + '</span>' : '');
        }

        if (window.history && window.history.replaceState) {
          var url = new URL(window.location.href);
          url.searchParams.set('variant', variant.id);
          window.history.replaceState({}, '', url);
        }

        updatePickup(variant.id);
      }

      var pickupWrap = pdp.querySelector('[data-pdp-pickup]');
      function updatePickup(variantId) {
        if (!pickupWrap || !variantId) return;
        var url = pickupWrap.dataset.productUrl + '?variant=' + variantId + '&section_id=pickup-availability';
        fetch(url).then(function (r) { return r.text(); }).then(function (text) {
          var holder = document.createElement('div');
          holder.innerHTML = text;
          var fresh = holder.querySelector('.pt-pickup');
          pickupWrap.innerHTML = fresh ? fresh.outerHTML : '';
        }).catch(function () {});
      }

      function setMainImage(src, mediaId) {
        if (mainMedia) {
          mainMedia.innerHTML = '<img class="pt-ph-img" src="' + src.replace(/(\.\w+)(\?|$)/, '_1200x1200$1$2') + '" alt="">';
          mainMedia.dataset.mediaId = mediaId || '';
        }
        thumbs.forEach(function (t) {
          t.dataset.on = mediaId && String(t.dataset.mediaId) === String(mediaId) ? '1' : '0';
        });
      }

      function setMainMedia(mediaId) {
        var tpl = mediaTemplates.filter(function (t) { return String(t.dataset.mediaId) === String(mediaId); })[0];
        if (!tpl || !mainMedia) return;
        mainMedia.innerHTML = tpl.innerHTML;
        mainMedia.dataset.mediaId = mediaId;
        thumbs.forEach(function (t) {
          t.dataset.on = String(t.dataset.mediaId) === String(mediaId) ? '1' : '0';
        });
      }

      fields.forEach(function (field) {
        var label = field.querySelector('[data-pdp-flabel]');
        var isSwatch = field.querySelector('.pt-pdp-colors') !== null;
        if (!isSwatch && label) {
          var i = parseInt(field.dataset.optIndex, 10);
          field.dataset.optLabel = /size/i.test(field.dataset.optName || '') ? i18n.sizeLabel
            : /length/i.test(field.dataset.optName || '') ? i18n.lengthLabel
            : label.textContent.split(' — ')[0];
        }
      });

      pdp.querySelectorAll('[data-pdp-option]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var i = parseInt(btn.dataset.optIndex, 10);
          selected[i] = btn.dataset.optValue;
          var wrap = btn.parentElement;
          wrap.querySelectorAll('[data-pdp-option]').forEach(function (b) { b.dataset.on = '0'; });
          btn.dataset.on = '1';
          render();
        });
      });

      thumbs.forEach(function (thumb) {
        thumb.addEventListener('click', function () {
          setMainMedia(thumb.dataset.mediaId);
        });
      });

      function setQty(v) {
        qtyVal = Math.max(1, v);
        if (qtyEl) qtyEl.value = qtyVal;
        updateAddButtons(findVariant());
      }
      if (qtyDec) qtyDec.addEventListener('click', function () { setQty(qtyVal - 1); });
      if (qtyInc) qtyInc.addEventListener('click', function () { setQty(qtyVal + 1); });
      if (qtyEl) qtyEl.addEventListener('change', function () { setQty(parseInt(qtyEl.value, 10) || 1); });

      var formEl = pdp.querySelector('form[action*="/cart/add"]');

      function addToCart(triggerBtn) {
        var variant = findVariant();
        if (!variant || !variant.available || !formEl) return;
        [addBtn, stickyAdd].forEach(function (b) { if (b) b.disabled = true; });
        var original = triggerBtn.textContent;
        triggerBtn.textContent = '…';

        var body = new FormData(formEl);
        body.set('id', variant.id);
        body.set('quantity', qtyVal);

        fetch('/cart/add.js', { method: 'POST', body: body }).then(function (r) {
          return r.json().then(function (data) {
            if (!r.ok) throw new Error(data.message || data.description || i18n.addError);
          });
        }).then(function () {
          var addonItems = [];
          pdp.querySelectorAll('[data-pdp-addon-check]:checked').forEach(function (cb) {
            var wrap = cb.closest('[data-pdp-addon]');
            addonItems.push({ id: parseInt(wrap.dataset.variantId, 10), quantity: 1 });
          });
          if (addonItems.length === 0) return;
          return fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: addonItems })
          });
        }).then(function () {
          if (window.ptShowToast) window.ptShowToast(i18n.addedToBag.replace('%%TITLE%%', pdp.dataset.productTitle));
          if (window.ptOpenCart) window.ptOpenCart();
          updateAddButtons(variant);
        }).catch(function (err) {
          updateAddButtons(variant);
          triggerBtn.textContent = original;
          if (window.ptShowToast) window.ptShowToast(err.message || i18n.addError);
        });
      }

      if (formEl) formEl.addEventListener('submit', function (e) { e.preventDefault(); addToCart(addBtn || stickyAdd); });
      if (variantSelect) updatePickup(variantSelect.value);
      if (stickyAdd) stickyAdd.addEventListener('click', function () { addToCart(stickyAdd); });

      var acc = pdp.querySelector('[data-pdp-acc]') || document.querySelector('[data-pdp-acc]');
      if (acc) {
        acc.addEventListener('click', function (e) {
          var btn = e.target.closest('[data-pdp-acc-toggle]');
          if (!btn) return;
          var item = btn.closest('[data-pdp-acc-item]');
          var willOpen = item.dataset.open !== '1';
          item.dataset.open = willOpen ? '1' : '0';
          btn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        });
      }


      var stickyJump = sticky ? sticky.querySelector('[data-pdp-sticky-jump]') : null;
      if (stickyJump) {
        stickyJump.addEventListener('click', function () {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }

      var copyBtn = pdp.querySelector('[data-pdp-copy-link]');
      var copiedEl = pdp.querySelector('[data-pdp-copied]');
      if (copyBtn) {
        copyBtn.addEventListener('click', function () {
          var url = window.location.href;
          if (navigator.clipboard) navigator.clipboard.writeText(url).catch(function () {});
          if (copiedEl) {
            copiedEl.hidden = false;
            copiedEl.textContent = i18n.copied;
            setTimeout(function () { copiedEl.hidden = true; }, 1800);
          }
        });
      }

      var buyRow = pdp.querySelector('.pt-pdp-actions');
      if (sticky && buyRow && 'IntersectionObserver' in window) {
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            sticky.classList.toggle('is-on', !entry.isIntersecting && entry.boundingClientRect.top < 0);
          });
        }, { threshold: 0 });
        observer.observe(buyRow);
      }
    });
  })();
{% endjavascript %}


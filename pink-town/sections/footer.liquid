<footer class="pt-footer full-width">
  <div class="pt-footer-top">
    <div class="pt-footer-brand">
      <a href="{{ routes.root_url }}" class="pt-logo pt-logo--foot">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="var(--pt-accent)" style="margin-right:2px" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
        {{ shop.name }}
      </a>
      <p class="pt-footer-tag">{{ section.settings.tagline | escape }}</p>
      <div class="pt-socials">
        {%- if section.settings.instagram_url != blank -%}
          <a href="{{ section.settings.instagram_url }}" class="pt-social" target="_blank" rel="noopener">Instagram</a>
        {%- endif -%}
        {%- if section.settings.tiktok_url != blank -%}
          <a href="{{ section.settings.tiktok_url }}" class="pt-social" target="_blank" rel="noopener">TikTok</a>
        {%- endif -%}
        {%- if section.settings.pinterest_url != blank -%}
          <a href="{{ section.settings.pinterest_url }}" class="pt-social" target="_blank" rel="noopener">Pinterest</a>
        {%- endif -%}
      </div>
    </div>

    <div class="pt-footer-cols">
      {%- for block in section.blocks -%}
        <div class="pt-footer-col" {{ block.shopify_attributes }}>
          <h4>{{ block.settings.heading | escape }}</h4>
          <ul>
            {%- for link in block.settings.menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endfor -%}
    </div>
  </div>

  <div class="pt-footer-utils">
    {%- if section.settings.show_country_selector and localization.available_countries.size > 1 -%}
      {%- form 'localization', id: 'pt-country-form', class: 'pt-loc-form' -%}
        <label for="pt-country-select">{{ 'general.localization.country_label' | t }}</label>
        <select id="pt-country-select" name="country_code" data-loc-select>
          {%- for country in localization.available_countries -%}
            <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>
              {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
            </option>
          {%- endfor -%}
        </select>
        <noscript><button type="submit" class="pt-loc-apply">{{ 'general.localization.apply' | t }}</button></noscript>
      {%- endform -%}
    {%- endif -%}

    {%- if section.settings.show_locale_selector and localization.available_languages.size > 1 -%}
      {%- form 'localization', id: 'pt-locale-form', class: 'pt-loc-form' -%}
        <label for="pt-locale-select">{{ 'general.localization.language_label' | t }}</label>
        <select id="pt-locale-select" name="locale_code" data-loc-select>
          {%- for language in localization.available_languages -%}
            <option value="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}selected{% endif %}>
              {{ language.endonym_name | capitalize }}
            </option>
          {%- endfor -%}
        </select>
        <noscript><button type="submit" class="pt-loc-apply">{{ 'general.localization.apply' | t }}</button></noscript>
      {%- endform -%}
    {%- endif -%}

    {%- if section.settings.show_follow_on_shop -%}
      <div class="pt-follow-shop">
        {{ shop | login_button: action: 'follow' }}
      </div>
    {%- endif -%}
  </div>

  <div class="pt-footer-bottom">
    <div class="pt-footer-bottom-row">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright_text | escape }}</span>
      {% if section.settings.show_payment_icons %}
        <div class="pt-pays">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag: class: 'pt-pay-icon' }}
          {% endfor %}
        </div>
      {% endif %}
    </div>
    {%- if shop.policies.size > 0 -%}
      <nav class="pt-footer-legal" aria-label="{{ 'general.accessibility.legal' | t }}">
        {%- for policy in shop.policies -%}
          <a href="{{ policy.url }}">{{ policy.title }}</a>
        {%- endfor -%}
      </nav>
    {%- endif -%}
  </div>
</footer>

{% stylesheet %}
  .pt-footer-utils { max-width: var(--pt-wrap); margin: 40px auto 0; display: flex; flex-wrap: wrap; align-items: flex-end; gap: 22px; padding-top: 28px; border-top: 1px solid var(--pt-line); }
  .pt-loc-form { display: flex; flex-direction: column; gap: 6px; }
  .pt-loc-form label { font-size: 11px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; color: var(--pt-ink-faint); }
  .pt-loc-form select { font-family: var(--pt-font-body); font-size: 13px; color: var(--pt-ink); border: 1px solid var(--pt-line); background: #fff; border-radius: 10px; padding: 9px 12px; max-width: 230px; }
  .pt-loc-form select:focus { outline: 2px solid var(--pt-accent); outline-offset: 1px; }
  .pt-loc-apply { margin-top: 6px; font-size: 12px; }
  .pt-follow-shop { margin-left: auto; }

  .pt-footer { background: #fff; border-top: 1px solid var(--pt-line); padding: 64px 32px 32px; font-family: var(--pt-font-body); }
  .pt-footer-top { max-width: var(--pt-wrap); margin: 0 auto; display: grid; grid-template-columns: 1.4fr 2fr; gap: 48px; }
  .pt-logo--foot { font-size: 26px; }
  .pt-footer-tag { color: var(--pt-ink-soft); font-size: 14px; max-width: 34ch; margin: 16px 0 20px; line-height: 1.6; }
  .pt-socials { display: flex; gap: 10px; flex-wrap: wrap; }
  .pt-social { font-size: 12.5px; font-weight: 600; color: var(--pt-accent-deep); border: 1px solid var(--pt-line); padding: 7px 14px; border-radius: 999px; transition: all .2s; }
  .pt-social:hover { background: var(--pt-accent-soft); border-color: var(--pt-accent); }
  .pt-footer-cols { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
  .pt-footer-col h4 { font-size: 12px; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; color: var(--pt-ink); margin-bottom: 14px; }
  .pt-footer-col li { margin-bottom: 9px; }
  .pt-footer-col a { font-size: 14px; color: var(--pt-ink-soft); transition: color .2s; }
  .pt-footer-col a:hover { color: var(--pt-accent-deep); }
  .pt-footer-bottom { max-width: var(--pt-wrap); margin: 44px auto 0; padding-top: 24px; border-top: 1px solid var(--pt-line); display: flex; flex-direction: column; gap: 14px; font-size: 12.5px; color: var(--pt-ink-faint); }
  .pt-footer-bottom-row { display: flex; align-items: center; justify-content: space-between; gap: 18px; flex-wrap: wrap; row-gap: 10px; }
  .pt-footer-legal { display: flex; flex-wrap: wrap; gap: 8px 18px; }
  .pt-footer-legal a:hover { color: var(--pt-accent-deep); }
  .pt-pays { display: flex; gap: 7px; align-items: center; flex-wrap: wrap; }
  .pt-pay-icon { height: 24px; width: auto; }
  @media (max-width: 980px) { .pt-footer-top { grid-template-columns: 1fr; gap: 36px; } }
  @media (max-width: 560px) {
    .pt-footer { padding: 44px 20px 24px; }
    .pt-footer-cols { grid-template-columns: repeat(2, 1fr); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "max_blocks": 4,
  "settings": [
    {
      "type": "textarea",
      "id": "tagline",
      "label": "t:labels.tagline",
      "default": "Fantasy looks at a fraction of the price. Tarnish-free, nickel-free & made to be adored."
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "t:labels.copyright_text",
      "default": "Imitation jewelry, real joy."
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "t:labels.instagram_url"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "t:labels.tiktok_url"
    },
    {
      "type": "url",
      "id": "pinterest_url",
      "label": "t:labels.pinterest_url"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_country_selector",
      "label": "t:labels.show_country_selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_locale_selector",
      "label": "t:labels.show_locale_selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_follow_on_shop",
      "label": "t:labels.show_follow_on_shop",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "t:sections.footer.blocks.link_column.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading",
          "default": "Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "t:labels.menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.footer",
      "blocks": [
        {
          "type": "link_column",
          "settings": {
            "heading": "Shop"
          }
        },
        {
          "type": "link_column",
          "settings": {
            "heading": "Help"
          }
        },
        {
          "type": "link_column",
          "settings": {
            "heading": "About"
          }
        }
      ]
    }
  ]
}
{% endschema %}

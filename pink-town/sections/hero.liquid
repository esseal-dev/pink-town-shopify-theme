{%- assign layout = section.settings.layout | default: 'split' -%}

{% if layout == 'centered' %}

<section class="pt-hero pt-hero--centered full-width" id="top">
  <div class="pt-hero-glow"></div>
  <div class="pt-hero-center">
    <span class="pt-eyebrow">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
      {{ section.settings.eyebrow | escape }}
    </span>
    <h1 class="pt-hero-h">{{ section.settings.heading }}</h1>
    <p class="pt-hero-sub">{{ section.settings.subheading | escape }}</p>
    <div class="pt-hero-ctas">
      <a href="{{ section.settings.cta_primary_url }}" class="pt-btn pt-btn--solid">{{ section.settings.cta_primary_text | escape }}</a>
      <a href="{{ section.settings.cta_secondary_url }}" class="pt-btn pt-btn--ghost">{{ section.settings.cta_secondary_text | escape }}</a>
    </div>
    {% if section.settings.show_stats %}
      <div class="pt-hero-stats">
        {%- if section.settings.stat_1_value != blank -%}
          <div class="pt-stat"><strong>{{ section.settings.stat_1_value | escape }}</strong><span>{{ section.settings.stat_1_label | escape }}</span></div>
        {%- endif -%}
        {%- if section.settings.stat_2_value != blank -%}
          <div class="pt-stat"><strong>{{ section.settings.stat_2_value | escape }}</strong><span>{{ section.settings.stat_2_label | escape }}</span></div>
        {%- endif -%}
        {%- if section.settings.stat_3_value != blank -%}
          <div class="pt-stat"><strong>{{ section.settings.stat_3_value | escape }}</strong><span>{{ section.settings.stat_3_label | escape }}</span></div>
        {%- endif -%}
      </div>
    {% endif %}
  </div>
  <div class="pt-hero-floats">
    <div class="pt-ph" style="width:230px;aspect-ratio:3/4;border-radius:140px 140px 18px 18px;background:var(--pt-bg-tint);--d:0s">
      {% if section.settings.image %}
        {{ section.settings.image | image_url: width: 460 | image_tag: class: 'pt-ph-img', loading: 'eager', alt: section.settings.image.alt }}
      {% endif %}
    </div>
    <div class="pt-ph" style="width:230px;margin-top:40px;aspect-ratio:3/4;border-radius:18px 18px 140px 140px;background:var(--pt-accent-soft);--d:0.15s">
      {% if section.settings.image_2 %}
        {{ section.settings.image_2 | image_url: width: 460 | image_tag: class: 'pt-ph-img', loading: 'lazy', alt: section.settings.image_2.alt }}
      {% endif %}
    </div>
  </div>
</section>

{% elsif layout == 'editorial' %}

<section class="pt-hero pt-hero--editorial full-width" id="top">
  <div class="pt-ph" style="position:absolute;inset:0;height:100%;border-radius:0;background:#f3dbe4;">
    {% if section.settings.image %}
      {{ section.settings.image | image_url: width: 1600 | image_tag: class: 'pt-ph-img', loading: 'eager', alt: section.settings.image.alt }}
    {% endif %}
  </div>
  <div class="pt-hero-scrim"></div>
  <div class="pt-hero-ed-copy">
    <span class="pt-eyebrow" style="color:#fff">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="#fff" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
      {{ section.settings.eyebrow | escape }}
    </span>
    <h1 class="pt-hero-h">{{ section.settings.heading }}</h1>
    <p class="pt-hero-sub">{{ section.settings.subheading | escape }}</p>
    <div class="pt-hero-ctas pt-hero-ctas--block">
      <a href="{{ section.settings.cta_primary_url }}" class="pt-btn pt-btn--solid">{{ section.settings.cta_primary_text | escape }}</a>
      <a href="{{ section.settings.cta_secondary_url }}" class="pt-btn pt-btn--ghost" style="color:#fff;border-color:rgba(255,255,255,.6)">{{ section.settings.cta_secondary_text | escape }}</a>
    </div>
  </div>
  {% if section.settings.editorial_tag != blank %}
    <div class="pt-hero-ed-tag">{{ section.settings.editorial_tag | escape }}</div>
  {% endif %}
</section>

{% else %}

<section class="pt-hero pt-hero--split full-width" id="top">
  <div class="pt-hero-copy">
    <span class="pt-eyebrow">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
      {{ section.settings.eyebrow | escape }}
    </span>
    <h1 class="pt-hero-h">{{ section.settings.heading }}</h1>
    <p class="pt-hero-sub">{{ section.settings.subheading | escape }}</p>
    <div class="pt-hero-ctas">
      <a href="{{ section.settings.cta_primary_url }}" class="pt-btn pt-btn--solid">{{ section.settings.cta_primary_text | escape }}</a>
      <a href="{{ section.settings.cta_secondary_url }}" class="pt-btn pt-btn--ghost">{{ section.settings.cta_secondary_text | escape }}</a>
    </div>
    {% if section.settings.show_stats %}
      <div class="pt-hero-stats">
        {%- if section.settings.stat_1_value != blank -%}
          <div class="pt-stat"><strong>{{ section.settings.stat_1_value | escape }}</strong><span>{{ section.settings.stat_1_label | escape }}</span></div>
        {%- endif -%}
        {%- if section.settings.stat_2_value != blank -%}
          <div class="pt-stat"><strong>{{ section.settings.stat_2_value | escape }}</strong><span>{{ section.settings.stat_2_label | escape }}</span></div>
        {%- endif -%}
        {%- if section.settings.stat_3_value != blank -%}
          <div class="pt-stat"><strong>{{ section.settings.stat_3_value | escape }}</strong><span>{{ section.settings.stat_3_label | escape }}</span></div>
        {%- endif -%}
      </div>
    {% endif %}
  </div>
  <div class="pt-hero-art">
    <div class="pt-hero-glow"></div>
    <div class="pt-ph" style="aspect-ratio:4/5;border-radius:200px 200px 22px 22px;background:var(--pt-bg-tint);position:relative;z-index:1;overflow:hidden;">
      {% if section.settings.image %}
        {{ section.settings.image | image_url: width: 900 | image_tag: class: 'pt-ph-img', loading: 'eager', alt: section.settings.image.alt }}
      {% else %}
        <span class="pt-ph-lbl">{{ 'sections.hero.image_placeholder' | t }}</span>
      {% endif %}
    </div>
    {%- if section.settings.chip_1_text != blank -%}
      <div class="pt-hero-chip pt-hero-chip--a">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c.6 4.8 2.6 6.8 7.4 7.4C14.6 10 12.6 12 12 16.8 11.4 12 9.4 10 4.6 9.4 9.4 8.8 11.4 6.8 12 2Z"/></svg>
        {{ section.settings.chip_1_text | escape }}
      </div>
    {%- endif -%}
    {%- if section.settings.chip_2_text != blank -%}
      <div class="pt-hero-chip pt-hero-chip--b">
        <span class="pt-stars" aria-hidden="true">
          {%- for i in (1..5) -%}<svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.4"><path d="M12 3.5l2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 17l-5.2 2.6 1-5.8L3.5 9.7l5.9-.9L12 3.5z" stroke-linejoin="round"/></svg>{%- endfor -%}
        </span>
        {{ section.settings.chip_2_text | escape }}
      </div>
    {%- endif -%}
  </div>
</section>

{% endif %}

{% stylesheet %}
  .pt-hero-h { font-family: var(--pt-font-head); font-weight: 500; line-height: .94; letter-spacing: -.015em; font-size: clamp(3.2rem, 7.2vw, 6rem); }
  .pt-hero-h em { font-style: italic; color: var(--pt-accent); }
  .pt-hero-sub { font-size: 18px; color: var(--pt-ink-soft); max-width: 46ch; margin: 26px 0 0; line-height: 1.65; text-wrap: pretty; }
  .pt-hero-ctas { display: flex; gap: 14px; margin-top: 34px; flex-wrap: wrap; }
  .pt-hero-ctas--block { margin-top: 30px; }
  .pt-hero-stats { display: flex; gap: 34px; margin-top: 52px; }
  .pt-stat { display: flex; flex-direction: column; gap: 2px; }
  .pt-stat strong { font-family: var(--pt-font-head); font-size: 30px; font-weight: 600; color: var(--pt-accent-deep); line-height: 1; }
  .pt-stat span { font-size: 12.5px; color: var(--pt-ink-soft); max-width: 14ch; }
  .pt-hero-glow { position: absolute; border-radius: 50%; filter: blur(60px); background: radial-gradient(circle, var(--pt-accent-soft), transparent 70%); }
  .pt-hero--split { width: 100%; max-width: var(--pt-wrap); margin: 0 auto; padding: 70px 32px 96px; display: grid; grid-template-columns: 1.05fr .95fr; gap: 56px; align-items: center; overflow: hidden; }
  .pt-hero-art { position: relative; }
  .pt-hero--split .pt-hero-glow { inset: -12% -8% -12% -12%; }
  .pt-hero-chip { position: absolute; z-index: 2; display: inline-flex; align-items: center; gap: 7px; background: rgba(255,255,255,.92); backdrop-filter: blur(6px); border: 1px solid var(--pt-line); border-radius: 999px; padding: 9px 15px; font-size: 12.5px; font-weight: 600; box-shadow: var(--pt-shadow-sm); font-family: var(--pt-font-body); }
  .pt-hero-chip--a { top: 13%; left: -6%; }
  .pt-hero-chip--b { bottom: 11%; right: -4%; color: var(--pt-accent-deep); }
  .pt-hero--centered { position: relative; text-align: center; padding: 64px 32px 0; overflow: hidden; }
  .pt-hero--centered .pt-hero-glow { width: 620px; height: 620px; top: -180px; left: 50%; transform: translateX(-50%); }
  .pt-hero-center { position: relative; z-index: 2; max-width: 760px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; }
  .pt-hero--centered .pt-hero-sub { max-width: 46ch; }
  .pt-hero--centered .pt-hero-ctas, .pt-hero--centered .pt-hero-stats { justify-content: center; }
  .pt-hero-floats { position: relative; z-index: 1; display: flex; justify-content: center; gap: 26px; margin-top: 56px; padding-bottom: 70px; max-width: 760px; margin-left: auto; margin-right: auto; }
  .pt-hero-floats .pt-ph { box-shadow: var(--pt-shadow-md); animation: ptFloat 6s ease-in-out infinite; animation-delay: var(--d, 0s); }
  @keyframes ptFloat { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-14px); } }
  @media (prefers-reduced-motion: reduce) { .pt-hero-floats .pt-ph { animation: none; } }
  .pt-hero--editorial { position: relative; min-height: 86vh; display: flex; flex-direction: column; justify-content: flex-end; padding: 56px clamp(32px, 6vw, 90px); overflow: hidden; }
  .pt-hero-scrim { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(75,40,50,.5) 0%, rgba(75,40,50,.1) 55%, transparent 100%); }
  .pt-hero-ed-copy { position: relative; z-index: 2; max-width: 620px; color: #fff; }
  .pt-hero-ed-copy .pt-hero-h em { color: #ffe3ea; }
  .pt-hero-ed-copy .pt-hero-sub { color: rgba(255,255,255,.9); max-width: 42ch; }
  .pt-hero-ed-tag { position: absolute; top: 40px; right: clamp(32px,6vw,90px); z-index: 2; color: #fff; font-size: 12px; letter-spacing: .18em; text-transform: uppercase; opacity: .9; font-family: var(--pt-font-body); }
  @media (max-width: 980px) {
    .pt-hero--split { grid-template-columns: 1fr; gap: 36px; padding-top: 44px; }
    .pt-hero-chip--a { left: 2%; } .pt-hero-chip--b { right: 2%; }
  }
  @media (max-width: 760px) {
    .pt-hero-stats { gap: 22px; }
    .pt-hero--centered { padding: 44px 20px 0; }
    .pt-hero--split { padding: 44px 20px 60px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.hero.name",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "t:labels.layout",
      "options": [
        { "value": "split", "label": "t:options.hero_layout.split" },
        { "value": "centered", "label": "t:options.hero_layout.centered" },
        { "value": "editorial", "label": "t:options.hero_layout.editorial" }
      ],
      "default": "split"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "t:labels.image_2"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Imitation fine jewelry"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Little luxuries, <em>big</em> sparkle."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:labels.subheading",
      "default": "Unique, dreamy jewelry that looks like a fortune and costs like a treat. Wear it everywhere — it won't tarnish, fade, or fuss."
    },
    {
      "type": "text",
      "id": "cta_primary_text",
      "label": "t:labels.cta_primary_text",
      "default": "Shop the collection"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "t:labels.cta_primary_url"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "t:labels.cta_secondary_text",
      "default": "Explore looks"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "t:labels.cta_secondary_url"
    },
    {
      "type": "text",
      "id": "editorial_tag",
      "label": "t:labels.editorial_tag",
      "default": "Spring drop — 'Soft Focus'"
    },
    {
      "type": "checkbox",
      "id": "show_stats",
      "label": "t:labels.show_stats",
      "default": true
    },
    {
      "type": "text",
      "id": "stat_1_value",
      "label": "t:labels.stat_1_value"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "t:labels.stat_1_label"
    },
    {
      "type": "text",
      "id": "stat_2_value",
      "label": "t:labels.stat_2_value"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "t:labels.stat_2_label"
    },
    {
      "type": "text",
      "id": "stat_3_value",
      "label": "t:labels.stat_3_value"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "t:labels.stat_3_label"
    },
    {
      "type": "text",
      "id": "chip_1_text",
      "label": "t:labels.chip_1_text"
    },
    {
      "type": "text",
      "id": "chip_2_text",
      "label": "t:labels.chip_2_text"
    }
  ],
  "presets": [
    {
      "name": "t:sections.hero.name"
    }
  ]
}
{% endschema %}

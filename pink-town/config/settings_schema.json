[
  {
    "name": "theme_info",
    "theme_name": "TriSoul Pink",
    "theme_version": "0.1.0",
    "theme_author": "TriSoul Digital",
    "theme_documentation_url": "https://wwww.themes.trisouldigital.com/trisoul-pink",
    "theme_support_url": "https://www.support.trisouldigital.com"
  },
  {
    "name": "t:general.favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "t:labels.favicon",
        "info": "t:labels.favicon_info"
      }
    ]
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "cormorant_n5",
        "label": "t:labels.heading_font"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "default": "muli_n4",
        "label": "t:labels.body_font"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "header",
        "content": "t:labels.color_page"
      },
      {
        "type": "color",
        "id": "color_background",
        "default": "#FFFAFB",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "color_text",
        "default": "#4B3138",
        "label": "t:labels.text_color"
      },
      {
        "type": "color",
        "id": "color_border",
        "default": "#F1DDE4",
        "label": "t:labels.border_color"
      },
      {
        "type": "header",
        "content": "t:labels.color_accent"
      },
      {
        "type": "color",
        "id": "color_accent",
        "default": "#B76E79",
        "label": "t:labels.accent_background"
      },
      {
        "type": "color",
        "id": "color_accent_text",
        "default": "#FFFFFF",
        "label": "t:labels.accent_text"
      },
      {
        "type": "header",
        "content": "t:labels.color_inputs"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      }
    ]
  }
]
